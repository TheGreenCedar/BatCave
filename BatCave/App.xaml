<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="BatCave.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:BatCave.Converters"
    xmlns:local="using:BatCave">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <converters:CpuPercentConverter x:Key="CpuPercentConverter" />
            <converters:BytesConverter x:Key="BytesConverter" />
            <converters:BytesRateConverter x:Key="BytesRateConverter" />
            <converters:AccessStateConverter x:Key="AccessStateConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

                    <Color x:Key="BatCavePrimaryColor">#FF3B82F6</Color>
                    <Color x:Key="BatCaveSecondaryColor">#FF10B981</Color>
                    <Color x:Key="BatCaveAccentColor">#FFF59E0B</Color>
                    <Color x:Key="BatCaveBorderColor">#FFE5E7EB</Color>

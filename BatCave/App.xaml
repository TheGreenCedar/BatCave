                    <Color x:Key="BatCaveSuccessColor">#FF059669</Color>
                    <Color x:Key="BatCaveWarningColor">#FFD97706</Color>
                    <Color x:Key="BatCaveSelectionColor">#FFDBEAFE</Color>
                    <Color x:Key="BatCaveSelectionTextColor">#FF111827</Color>
                    <Color x:Key="BatCaveGhostTextColor">#FF334155</Color>
                    <Color x:Key="BatCaveOnPrimaryColor">#FFFFFFFF</Color>
                    <Color x:Key="BatCaveBannerInfoSurfaceColor">#FFE8F1FF</Color>
                    <Color x:Key="BatCaveBannerSuccessSurfaceColor">#FFE7F8F0</Color>
                    <Color x:Key="BatCaveBannerWarningSurfaceColor">#FFFEF3C7</Color>
                    <Color x:Key="BatCaveBannerErrorSurfaceColor">#FFFEE2E2</Color>
                    <Color x:Key="BatCaveSegmentSurfaceColor">#FFE7EDF5</Color>
                    <Color x:Key="BatCaveSegmentSelectedColor">#FF3B82F6</Color>

                    <Color x:Key="ChartCpuStrokeColor">#FF3B82F6</Color>

                <ResourceDictionary x:Key="Light">
                    <Color x:Key="BatCaveCanvasColor">#FFFFFFFF</Color>
                    <Color x:Key="BatCaveHeaderColor">#FFF1F5F9</Color>
                    <Color x:Key="BatCavePanelColor">#FFFFFFFF</Color>
                    <Color x:Key="BatCavePanelAltColor">#FFE9EFF7</Color>
                    <Color x:Key="BatCaveMutedColor">#FFDCE6F3</Color>
                    <Color x:Key="BatCaveTextPrimaryColor">#FF111827</Color>

                    <Color x:Key="ChartIoReadStrokeColor">#FFF59E0B</Color>
                    <Color x:Key="ChartIoReadFillColor">#22F59E0B</Color>
                    <Color x:Key="ChartIoWriteStrokeColor">#FFEA580C</Color>
                    <Color x:Key="ChartIoWriteFillColor">#22EA580C</Color>
                    <Color x:Key="ChartOtherIoStrokeColor">#FF7C3AED</Color>
                    <Color x:Key="ChartOtherIoFillColor">#227C3AED</Color>
                    <Color x:Key="ChartNetworkStrokeColor">#FF0F766E</Color>
                    <Color x:Key="ChartNetworkFillColor">#220F766E</Color>

<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BatCave.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BatCave">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="16"
            BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="BatCave Monitor" />
                <TextBlock Opacity="0.8" Text="Windows-native process telemetry with runtime parity." />
                <TextBox
                    PlaceholderText="Filter by name or PID"
                    Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ToggleSwitch
                        Header="Admin Mode"
                        IsEnabled="{x:Bind ViewModel.IsLive, Mode=OneWay}"
                        IsOn="{x:Bind ViewModel.AdminModeEnabled, Mode=OneWay}"
                        Toggled="AdminModeToggle_Toggled" />
                    <CheckBox
                        VerticalAlignment="Center"
                        Content="Admin-enabled only"
                        IsChecked="{x:Bind ViewModel.AdminEnabledOnlyFilter, Mode=TwoWay}"
                        IsEnabled="{x:Bind ViewModel.AdminModeEnabled, Mode=OneWay}" />
                </StackPanel>
                <TextBlock
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Text="{x:Bind ViewModel.AdminModeError, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind ViewModel.AdminErrorVisibility, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Padding="16">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}">
                <ProgressRing IsActive="True" />
                <TextBlock Text="Starting monitoring runtime..." />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.BlockedVisibility, Mode=OneWay}">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Startup Blocked" />
                <TextBlock MaxWidth="760" Text="{x:Bind ViewModel.BlockedReasonMessage, Mode=OneWay}" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.StartupErrorVisibility, Mode=OneWay}">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Startup Error" />
                <TextBlock MaxWidth="760" Text="{x:Bind ViewModel.StartupErrorMessage, Mode=OneWay}" TextWrapping="Wrap" />
                <Button Click="RetryBootstrap_Click" Content="Retry" />
            </StackPanel>

            <Grid Visibility="{x:Bind ViewModel.LiveVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,8" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="1.3*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="SortHeader_Click" Content="{x:Bind ViewModel.NameSortLabel, Mode=OneWay}" Tag="Name" />
                            <Button Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Click="SortHeader_Click" Content="{x:Bind ViewModel.PidSortLabel, Mode=OneWay}" Tag="Pid" />
                            <Button Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Click="SortHeader_Click" Content="{x:Bind ViewModel.CpuSortLabel, Mode=OneWay}" Tag="CpuPct" />
                            <Button Grid.Column="3" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Click="SortHeader_Click" Content="{x:Bind ViewModel.MemorySortLabel, Mode=OneWay}" Tag="RssBytes" />
                            <Button Grid.Column="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Click="SortHeader_Click" Content="{x:Bind ViewModel.IoReadSortLabel, Mode=OneWay}" Tag="IoReadBps" />
                            <Button Grid.Column="5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Click="SortHeader_Click" Content="{x:Bind ViewModel.IoWriteSortLabel, Mode=OneWay}" Tag="IoWriteBps" />
                            <Button Grid.Column="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Click="SortHeader_Click" Content="{x:Bind ViewModel.NetSortLabel, Mode=OneWay}" Tag="NetBps" />
                            <Button Grid.Column="7" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Click="SortHeader_Click" Content="{x:Bind ViewModel.ThreadsSortLabel, Mode=OneWay}" Tag="Threads" />
                            <Button Grid.Column="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Click="SortHeader_Click" Content="{x:Bind ViewModel.HandlesSortLabel, Mode=OneWay}" Tag="Handles" />
                            <TextBlock Grid.Column="9" VerticalAlignment="Center" FontWeight="SemiBold" Text="CPU Trend" />
                        </Grid>

                        <ListView
                            x:Name="ProcessListView"
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.VisibleRows, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedVisibleRow, Mode=OneWay}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectionChanged="ProcessListView_SelectionChanged"
                            SelectionMode="Single">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MinHeight" Value="30" />
                                    <Setter Property="Padding" Value="3,2" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="2,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1.3*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{Binding Pid}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="2" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{Binding CpuPct, Converter={StaticResource CpuPercentConverter}}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="3" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{Binding RssBytes, Converter={StaticResource BytesConverter}}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="4" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{Binding IoReadBps, Converter={StaticResource BytesRateConverter}}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="5" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{Binding IoWriteBps, Converter={StaticResource BytesRateConverter}}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="6" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{Binding NetBps, Converter={StaticResource BytesRateConverter}}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="7" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{Binding Threads}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="8" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{Binding Handles}" TextAlignment="Right" />
                                        <Canvas Grid.Column="9" Width="96" Height="22" HorizontalAlignment="Stretch">
                                            <Polyline
                                                Points="{Binding CpuTrendPoints}"
                                                Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                StrokeLineJoin="Round"
                                                StrokeStartLineCap="Round"
                                                StrokeEndLineCap="Round"
                                                StrokeThickness="2.5" />
                                        </Canvas>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.DetailTitle, Mode=OneWay}" />
                            <Button Click="ClearSelection_Click" Content="Clear Selection" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />

                            <TextBlock FontWeight="SemiBold" Text="Metric Trends" />

                            <ToggleButton
                                HorizontalContentAlignment="Stretch"
                                IsChecked="{x:Bind ViewModel.IsCpuMetricFocused, Mode=OneWay}"
                                Tag="Cpu"
                                Click="MetricChip_Click">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="CPU" />
                                        <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.CpuMetricChipValue, Mode=OneWay}" />
                                    </StackPanel>
                                    <Canvas Grid.Column="1" Width="206" Height="36" HorizontalAlignment="Stretch">
                                        <Polyline Points="{x:Bind ViewModel.CpuMetricTrendPoints, Mode=OneWay}" Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                    </Canvas>
                                </Grid>
                            </ToggleButton>

                            <ToggleButton
                                HorizontalContentAlignment="Stretch"
                                IsChecked="{x:Bind ViewModel.IsMemoryMetricFocused, Mode=OneWay}"
                                Tag="Memory"
                                Click="MetricChip_Click">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Memory" />
                                        <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.MemoryMetricChipValue, Mode=OneWay}" />
                                    </StackPanel>
                                    <Canvas Grid.Column="1" Width="206" Height="36" HorizontalAlignment="Stretch">
                                        <Polyline Points="{x:Bind ViewModel.MemoryMetricTrendPoints, Mode=OneWay}" Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                    </Canvas>
                                </Grid>
                            </ToggleButton>

                            <ToggleButton
                                HorizontalContentAlignment="Stretch"
                                IsChecked="{x:Bind ViewModel.IsIoReadMetricFocused, Mode=OneWay}"
                                Tag="IoRead"
                                Click="MetricChip_Click">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Disk Read" />
                                        <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.IoReadMetricChipValue, Mode=OneWay}" />
                                    </StackPanel>
                                    <Canvas Grid.Column="1" Width="206" Height="36" HorizontalAlignment="Stretch">
                                        <Polyline Points="{x:Bind ViewModel.IoReadMetricTrendPoints, Mode=OneWay}" Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                    </Canvas>
                                </Grid>
                            </ToggleButton>

                            <ToggleButton
                                HorizontalContentAlignment="Stretch"
                                IsChecked="{x:Bind ViewModel.IsIoWriteMetricFocused, Mode=OneWay}"
                                Tag="IoWrite"
                                Click="MetricChip_Click">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Disk Write" />
                                        <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.IoWriteMetricChipValue, Mode=OneWay}" />
                                    </StackPanel>
                                    <Canvas Grid.Column="1" Width="206" Height="36" HorizontalAlignment="Stretch">
                                        <Polyline Points="{x:Bind ViewModel.IoWriteMetricTrendPoints, Mode=OneWay}" Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                    </Canvas>
                                </Grid>
                            </ToggleButton>

                            <ToggleButton
                                HorizontalContentAlignment="Stretch"
                                IsChecked="{x:Bind ViewModel.IsNetworkMetricFocused, Mode=OneWay}"
                                Tag="Network"
                                Click="MetricChip_Click">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Network" />
                                        <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.NetworkMetricChipValue, Mode=OneWay}" />
                                    </StackPanel>
                                    <Canvas Grid.Column="1" Width="206" Height="36" HorizontalAlignment="Stretch">
                                        <Polyline Points="{x:Bind ViewModel.NetworkMetricTrendPoints, Mode=OneWay}" Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                    </Canvas>
                                </Grid>
                            </ToggleButton>

                            <Border
                                Padding="10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.ExpandedMetricTitle, Mode=OneWay}" />
                                        <TextBlock Grid.Column="1" FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.ExpandedMetricValue, Mode=OneWay}" />
                                    </Grid>
                                    <Viewbox Grid.Row="1" Stretch="Fill" Height="220">
                                        <Canvas Width="960" Height="360">
                                            <Polyline
                                                Points="{x:Bind ViewModel.ExpandedMetricTrendPoints, Mode=OneWay}"
                                                Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                StrokeLineJoin="Round"
                                                StrokeStartLineCap="Round"
                                                StrokeEndLineCap="Round"
                                                StrokeThickness="4" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Border>

                            <TextBlock FontWeight="SemiBold" Text="Metadata Status" />
                            <TextBlock Text="{x:Bind ViewModel.MetadataStatus, Mode=OneWay}" TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Parent PID" />
                            <TextBlock Text="{x:Bind ViewModel.MetadataParentPid, Mode=OneWay}" />
                            <TextBlock FontWeight="SemiBold" Text="Executable Path" />
                            <TextBlock Text="{x:Bind ViewModel.MetadataExecutablePath, Mode=OneWay}" TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="Command Line" />
                            <TextBlock Text="{x:Bind ViewModel.MetadataCommandLine, Mode=OneWay}" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="12"
            BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="Runtime Health:" />
                <TextBlock Text="{x:Bind ViewModel.RuntimeHealthStatus, Mode=OneWay}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

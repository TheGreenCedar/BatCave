                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCaveSecondaryBrush}"
                            Opacity="0.44"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path

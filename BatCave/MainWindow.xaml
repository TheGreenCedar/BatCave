                        <Path
                            x:Name="HeaderBatAccentPhoneLeft"
                            Width="30"
                            Height="14"
                            Margin="44,18,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCaveSecondaryBrush}"
                            Opacity="0.46"
                            IsHitTestVisible="False"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderBatAccentPhoneRight"
                            Width="30"
                            Height="14"
                            Margin="0,18,44,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCavePrimaryBrush}"
                            Opacity="0.46"
                            IsHitTestVisible="False"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderBatAccentPhoneFarRight"
                            Width="34"
                            Height="16"
                            Margin="0,12,16,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCavePrimaryBrush}"
                            Opacity="0.56"
                            IsHitTestVisible="False"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderCaveHostPhone"
                            Stretch="Fill"
                            Fill="{ThemeResource BatCaveHeroCaveShellBrush}"
                            Stroke="{ThemeResource BatCaveHeroCaveStrokeBrush}"
                            StrokeThickness="1.3"
                            Data="M14,64 Q26,38 56,20 L82,30 L116,10 L150,30 Q180,20 204,64 L180,64 Q164,48 142,42 L116,64 L94,64 L70,42 Q48,48 32,64 Z" />
                        <Path
                            x:Name="HeaderCaveCrestPhone"
                            Margin="22,8,22,0"
                            Stretch="Fill"
                            Fill="{ThemeResource BatCavePanelAltBrush}"
                            Opacity="0.42"
                            Data="M28,30 Q50,14 78,18 L98,14 L118,18 Q146,14 168,30 L150,30 Q132,24 116,26 Q100,24 82,30 Z" />
                        <Border
                            x:Name="HeaderBrandSurfacePhone"
                            Margin="52,28,52,10"
                            Padding="18,8,18,8"
                            Background="{ThemeResource BatCavePanelBrush}"
                            BorderBrush="{ThemeResource BatCaveHeroCaveStrokeBrush}"
                            BorderThickness="1.25"
                            CornerRadius="15">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    Style="{StaticResource BatCaveTitleTextStyle}"
                                    HorizontalAlignment="Center"
                                    Text="{ThemeResource ShellTitleText}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,10,0,0" Height="48">
                        <Border
                            Background="{ThemeResource BatCaveHeroInputSurfaceBrush}"
                            BorderBrush="{ThemeResource BatCaveHeroCaveStrokeBrush}"
                            BorderThickness="1.25"
                            CornerRadius="14" />
                        <TextBox
                            x:Name="FilterTextBoxPhone"
                            Margin="14,0,14,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{ThemeResource BatCaveTextPrimaryBrush}"
                            PlaceholderForeground="{ThemeResource BatCaveHeroInputPlaceholderBrush}"
                            PlaceholderText="{ThemeResource FilterPlaceholderText}"
                            Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Padding="4,0"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            AutomationProperties.HelpText="{ThemeResource ProcessFilterHelpText}"
                            AutomationProperties.Name="Process Filter" />
                    </Grid>
                    <Border
                        x:Name="HeaderAdminSurfacePhone"
                        Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="12,8"
                        Background="{ThemeResource BatCaveHeroInputSurfaceBrush}"
                        BorderBrush="{ThemeResource BatCaveHeroCaveStrokeBrush}"
                        BorderThickness="1.25"
                        CornerRadius="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource BatCaveTextPrimaryBrush}" Text="Admin Mode" />
                            <ToggleSwitch
                                x:Name="AdminModeTogglePhone"
                                Header=""
                                IsOn="{x:Bind ViewModel.AdminModeEnabled, Mode=OneWay}"
                                OffContent=""
                                OnContent=""
                                Toggled="AdminModeToggle_Toggled"
                                AutomationProperties.HelpText="{ThemeResource AdminToggleHelpText}"
                                AutomationProperties.Name="Admin Mode Toggle" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Margin="18,0,18,0"
            Padding="0"
            Background="{Binding ViewModel.RuntimeStatusSurfaceBrush, ElementName=RootWindow, Mode=OneWay}"
            BorderBrush="Transparent"
            BorderThickness="0"
            Visibility="{Binding ViewModel.RuntimeStatusVisibility, ElementName=RootWindow, Mode=OneWay}"
            AutomationProperties.Name="Runtime Status Strip">
            <Grid ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Rectangle Width="6" Fill="{Binding ViewModel.RuntimeStatusAccentBrush, ElementName=RootWindow, Mode=OneWay}" />
                <Border
                    Grid.Column="1"
                    Margin="12,6,10,6"
                    Padding="8,3"
                    Background="{Binding ViewModel.RuntimeStatusTagBackgroundBrush, ElementName=RootWindow, Mode=OneWay}"
                    CornerRadius="6">
                    <TextBlock
                        Style="{StaticResource BatCaveMetricLabelStyle}"
                        Foreground="{Binding ViewModel.RuntimeStatusTagForegroundBrush, ElementName=RootWindow, Mode=OneWay}"
                        VerticalAlignment="Center"
                        Text="{Binding ViewModel.RuntimeStatusTag, ElementName=RootWindow, Mode=OneWay}" />
                </Border>
                <TextBlock
                    Grid.Column="2"
                    Visibility="Collapsed" />
                <StackPanel Grid.Column="2" Margin="0,6,14,6" Spacing="2">
                    <TextBlock
                        Foreground="{Binding ViewModel.RuntimeStatusTitleBrush, ElementName=RootWindow, Mode=OneWay}"
                        FontWeight="SemiBold"
                        Text="{Binding ViewModel.RuntimeStatusTitle, ElementName=RootWindow, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource BatCaveSectionSubtitleStyle}"
                        Foreground="{Binding ViewModel.RuntimeStatusSummaryBrush, ElementName=RootWindow, Mode=OneWay}"
                        Text="{Binding ViewModel.RuntimeStatusSummary, ElementName=RootWindow, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ContentRegion" Grid.Row="2" Padding="{ThemeResource ShellContentPadding}">
            <controls:StartupStatePanel DataContext="{x:Bind ViewModel, Mode=OneWay}" />

            <Grid x:Name="WorkspaceRoot" Margin="0,-8,0,0" Visibility="{x:Bind ViewModel.LiveVisibility, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition x:Name="WorkspaceInspectorRow" Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="WorkspaceLeftColumn" Width="6*" />
                    <ColumnDefinition x:Name="WorkspaceRightColumn" Width="6*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource BatCaveFlatPanelBorderStyle}">
                    <Grid Padding="18,2,18,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource BatCaveEyebrowTextStyle}" Text="PROCESS EXPLORER" />
                                <TextBlock Style="{StaticResource BatCaveSectionTitleStyle}" Text="Active Processes" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="1" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <TextBlock Style="{StaticResource BatCaveEyebrowTextStyle}" Text="COUNT" />
                                <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Foreground="{ThemeResource BatCaveTextPrimaryBrush}" Text="{x:Bind ViewModel.CompactNameTotalLabel, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Margin="0,12,0,12"
                            Background="{ThemeResource BatCaveMutedBrush}"
                            CornerRadius="8"
                            Padding="10,8">
                            <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Grid.Column="0"
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                Click="CompactProcessSortHeader_Click"
                                CommandParameter="Name"
                                Background="{x:Bind ViewModel.CompactNameColumnBackground, Mode=OneWay}"
                                BorderThickness="0"
                                HorizontalContentAlignment="Left"
                                AutomationProperties.Name="{x:Bind ViewModel.CompactNameSortAutomationName, Mode=OneWay}">
                                <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Foreground="{x:Bind ViewModel.CompactNameSortForeground, Mode=OneWay}" Text="{x:Bind ViewModel.CompactNameSortLabel, Mode=OneWay}" />
                            </Button>

                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                Click="CompactProcessSortHeader_Click"
                                CommandParameter="CpuPct"
                                Background="{x:Bind ViewModel.CompactCpuColumnBackground, Mode=OneWay}"
                                BorderThickness="0"
                                HorizontalContentAlignment="Right"
                                AutomationProperties.Name="{x:Bind ViewModel.CompactCpuSortAutomationName, Mode=OneWay}">
                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource BatCaveMetricLabelStyle}" Foreground="{x:Bind ViewModel.CompactCpuSortForeground, Mode=OneWay}" Text="{x:Bind ViewModel.CompactCpuSortLabel, Mode=OneWay}" />
                            </Button>

                            <Button
                                Grid.Column="2"
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                Click="CompactProcessSortHeader_Click"
                                CommandParameter="RssBytes"
                                Background="{x:Bind ViewModel.CompactMemoryColumnBackground, Mode=OneWay}"
                                BorderThickness="0"
                                HorizontalContentAlignment="Right"
                                AutomationProperties.Name="{x:Bind ViewModel.CompactMemorySortAutomationName, Mode=OneWay}">
                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource BatCaveMetricLabelStyle}" Foreground="{x:Bind ViewModel.CompactMemorySortForeground, Mode=OneWay}" Text="{x:Bind ViewModel.CompactMemorySortLabel, Mode=OneWay}" />
                            </Button>

                            <Button
                                Grid.Column="3"
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                Click="CompactProcessSortHeader_Click"
                                CommandParameter="DiskBps"
                                Background="{x:Bind ViewModel.CompactDiskColumnBackground, Mode=OneWay}"
                                BorderThickness="0"
                                HorizontalContentAlignment="Right"
                                AutomationProperties.Name="{x:Bind ViewModel.CompactDiskSortAutomationName, Mode=OneWay}">
                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource BatCaveMetricLabelStyle}" Foreground="{x:Bind ViewModel.CompactDiskSortForeground, Mode=OneWay}" Text="{x:Bind ViewModel.CompactDiskSortLabel, Mode=OneWay}" />
                            </Button>

                            <Button
                                Grid.Column="4"
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                Click="CompactProcessSortHeader_Click"
                                CommandParameter="OtherIoBps"
                                Background="{x:Bind ViewModel.CompactNetworkColumnBackground, Mode=OneWay}"
                                BorderThickness="0"
                                HorizontalContentAlignment="Right"
                                AutomationProperties.Name="{x:Bind ViewModel.CompactNetworkSortAutomationName, Mode=OneWay}">
                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource BatCaveMetricLabelStyle}" Foreground="{x:Bind ViewModel.CompactNetworkSortForeground, Mode=OneWay}" Text="{x:Bind ViewModel.CompactEstimatedTrafficSortLabel, Mode=OneWay}" />
                            </Button>
                            </Grid>
                        </Border>

                        <ListView
                            x:Name="CompactProcessListView"
                            Grid.Row="2"
                            Background="Transparent"
                            ItemsSource="{x:Bind ViewModel.VisibleRows, Mode=OneWay}"
                            IsItemClickEnabled="True"
                            ItemClick="ProcessListView_ItemClick"
                            SelectionMode="None"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            AutomationProperties.HelpText="Compact process table with name, PID, CPU, memory, disk, and estimated network columns."
                            AutomationProperties.Name="Compact Process Table">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel ItemsUpdatingScrollMode="KeepScrollOffset" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.Resources>
                                <StaticResource x:Key="ListViewItemBackgroundSelected" ResourceKey="BatCaveSelectionBrush" />
                                <StaticResource x:Key="ListViewItemBackgroundSelectedPointerOver" ResourceKey="BatCaveSelectionBrush" />
                                <StaticResource x:Key="ListViewItemBackgroundSelectedPressed" ResourceKey="BatCavePrimaryBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelected" ResourceKey="BatCaveSelectionTextBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelectedPointerOver" ResourceKey="BatCaveSelectionTextBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelectedPressed" ResourceKey="BatCaveSelectionTextBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorBrush" ResourceKey="BatCavePrimaryBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorPointerOverBrush" ResourceKey="BatCavePrimaryBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorPressedBrush" ResourceKey="BatCavePrimaryBrush" />
                                <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">True</x:Boolean>
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MinHeight" Value="38" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,2" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ProcessRowViewState">
                                    <Grid Background="Transparent">
                                        <Border
                                            Background="{ThemeResource BatCaveSelectionBrush}"
                                            CornerRadius="8"
                                            Visibility="{x:Bind SelectionChromeVisibility, Mode=OneWay}" />
                                        <Grid Padding="8,6" AutomationProperties.Name="{x:Bind AccessibilitySummary, Mode=OneWay}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2.2*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="1*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="1">
                                                <TextBlock Foreground="{ThemeResource BatCaveTextPrimaryBrush}" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Text="{x:Bind CompactPidText, Mode=OneWay}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Style="{StaticResource BatCaveMetricValueStyle}" HorizontalAlignment="Right" Text="{x:Bind CpuText, Mode=OneWay}" TextAlignment="Right" />
                                            <TextBlock Grid.Column="2" Style="{StaticResource BatCaveMetricValueStyle}" HorizontalAlignment="Right" Text="{x:Bind RssText, Mode=OneWay}" TextAlignment="Right" />
                                            <TextBlock Grid.Column="3" Style="{StaticResource BatCaveMetricValueStyle}" HorizontalAlignment="Right" Text="{x:Bind DiskText, Mode=OneWay}" TextAlignment="Right" />
                                            <TextBlock Grid.Column="4" Style="{StaticResource BatCaveMetricValueStyle}" HorizontalAlignment="Right" Text="{x:Bind NetworkEstimateText, Mode=OneWay}" TextAlignment="Right" />
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border x:Name="WorkspaceInspectorPane" Grid.Row="0" Grid.Column="1" Background="{ThemeResource BatCavePanelBrush}" CornerRadius="8">
                    <Grid Padding="18,4,18,18" RowSpacing="12" DataContext="{x:Bind ViewModel, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource BatCaveEyebrowTextStyle}" Text="INSPECTOR" />
                                <TextBlock Style="{StaticResource BatCaveSectionTitleStyle}" Text="{Binding InspectorContextTitle, Mode=OneWay}" />
                                <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Text="{Binding InspectorContextSubtitle, Mode=OneWay}" />
                            </StackPanel>

                            <Border
                                Grid.Column="1"
                                Background="{ThemeResource BatCaveMutedBrush}"
                                CornerRadius="8"
                                Padding="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <RadioButton
                                        GroupName="TrendWindowGroup"
                                        Style="{StaticResource BatCaveSegmentRadioButtonStyle}"
                                        Content="60s"
                                        IsChecked="{Binding IsTrendWindow60Selected, Mode=OneWay}"
                                        Background="{Binding Trend60BackgroundBrush, Mode=OneWay}"
                                        Foreground="{Binding Trend60ForegroundBrush, Mode=OneWay}"
                                        Command="{Binding MetricTrendWindowSelectedCommand}"
                                        CommandParameter="60" />
                                    <RadioButton
                                        GroupName="TrendWindowGroup"
                                        Style="{StaticResource BatCaveSegmentRadioButtonStyle}"
                                        Content="120s"
                                        IsChecked="{Binding IsTrendWindow120Selected, Mode=OneWay}"
                                        Background="{Binding Trend120BackgroundBrush, Mode=OneWay}"
                                        Foreground="{Binding Trend120ForegroundBrush, Mode=OneWay}"
                                        Command="{Binding MetricTrendWindowSelectedCommand}"
                                        CommandParameter="120" />
                                    <RadioButton
                                        GroupName="CpuModeGroup"
                                        Style="{StaticResource BatCaveSegmentRadioButtonStyle}"
                                        Visibility="{Binding GlobalCpuModeToggleVisibility, Mode=OneWay}"
                                        Content="Combined"
                                        IsChecked="{Binding IsCpuCombinedMode, Mode=OneWay}"
                                        Background="{Binding CombinedModeBackgroundBrush, Mode=OneWay}"
                                        Foreground="{Binding CombinedModeForegroundBrush, Mode=OneWay}"
                                        Command="{Binding CpuGraphModeSelectedCommand}"
                                        CommandParameter="Combined" />
                                    <RadioButton
                                        GroupName="CpuModeGroup"
                                        Style="{StaticResource BatCaveSegmentRadioButtonStyle}"
                                        Visibility="{Binding GlobalCpuModeToggleVisibility, Mode=OneWay}"
                                        Content="Logical"
                                        IsChecked="{Binding IsCpuLogicalMode, Mode=OneWay}"
                                        Background="{Binding LogicalModeBackgroundBrush, Mode=OneWay}"
                                        Foreground="{Binding LogicalModeForegroundBrush, Mode=OneWay}"
                                        Command="{Binding CpuGraphModeSelectedCommand}"
                                        CommandParameter="LogicalProcessors" />
                                    <Button
                                        Style="{StaticResource BatCaveGhostButtonStyle}"
                                        IsEnabled="{Binding HasSelection, Mode=OneWay}"
                                        Command="{Binding ClearSelectionRequestedCommand}"
                                        Content="Clear" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1">
                            <ListView
                                x:Name="GlobalResourceListView"
                                Background="Transparent"
                                BorderThickness="0"
                                Height="82"
                                Visibility="{Binding GlobalPerformanceContentVisibility, Mode=OneWay}"
                                ItemsSource="{Binding GlobalResourceRows, Mode=OneWay}"
                                SelectionChanged="GlobalResourceListView_SelectionChanged"
                                SelectionMode="Single"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListView.Resources>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent" />
                                    <StaticResource x:Key="ListViewItemForegroundSelected" ResourceKey="BatCaveTextPrimaryBrush" />
                                    <StaticResource x:Key="ListViewItemForegroundSelectedPointerOver" ResourceKey="BatCaveTextPrimaryBrush" />
                                    <StaticResource x:Key="ListViewItemForegroundSelectedPressed" ResourceKey="BatCaveTextPrimaryBrush" />
                                    <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">False</x:Boolean>
                                </ListView.Resources>
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="MinWidth" Value="128" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,6,0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding ContainerBackgroundBrush, Mode=OneWay}" BorderBrush="{Binding ContainerBorderBrush, Mode=OneWay}" BorderThickness="1.5" CornerRadius="8" Padding="8">
                                            <Grid RowSpacing="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <controls:MetricTrendChart
                                                    Width="44"
                                                    Height="28"
                                                    ChartIdentityKey="{Binding ChartIdentityKey, Mode=OneWay}"
                                                    Values="{Binding MiniTrendValues, Mode=OneWay}"
                                                    VisiblePointCount="{Binding ViewModel.MetricTrendWindowSeconds, ElementName=RootWindow, Mode=OneWay}"
                                                    ScaleMode="{Binding MiniScaleMode, Mode=OneWay}"
                                                    DomainMaxOverride="{Binding MiniDomainMax, Mode=OneWay}"
                                                    ShowGrid="False"
                                                    Background="Transparent"
                                                    EnableSmoothPointTransitions="{ThemeResource BatCaveChartSmoothTransitionsEnabled}"
                                                    AutomationProperties.Name="{Binding MiniChartAutomationName, Mode=OneWay}"
                                                    AutomationProperties.HelpText="{Binding MiniChartAutomationHelpText, Mode=OneWay}">
                                                    <controls:MetricTrendChart.StrokeBrush>
                                                        <SolidColorBrush Color="{Binding MiniStrokeColor, Mode=OneWay}" />
                                                    </controls:MetricTrendChart.StrokeBrush>
                                                    <controls:MetricTrendChart.FillBrush>
                                                        <SolidColorBrush Color="{Binding MiniFillColor, Mode=OneWay}" />
                                                    </controls:MetricTrendChart.FillBrush>
                                                </controls:MetricTrendChart>
                                                <StackPanel Grid.Column="1" Spacing="1">
                                                    <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Foreground="{Binding PrimaryTextBrush, Mode=OneWay}" Text="{Binding Title, Mode=OneWay}" />
                                                    <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Foreground="{Binding SecondaryTextBrush, Mode=OneWay}" Text="{Binding Subtitle, Mode=OneWay}" Visibility="{Binding SubtitleVisibility, Mode=OneWay}" />
                                                    <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Text="{Binding ValueText, Mode=OneWay}" Visibility="{Binding ValueVisibility, Mode=OneWay}" Foreground="{Binding SecondaryTextBrush, Mode=OneWay}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Grid Visibility="{Binding GlobalPerformanceSkeletonVisibility, Mode=OneWay}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Margin="0,0,6,0" Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="8" />
                                <Border Grid.Column="1" Margin="0,0,6,0" Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="8" />
                                <Border Grid.Column="2" Margin="0,0,6,0" Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="8" />
                                <Border Grid.Column="3" Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="8" />
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Row="2" Spacing="6">
                            <TextBlock Style="{StaticResource BatCaveEyebrowTextStyle}" Text="{Binding InspectorOverviewEyebrow, Mode=OneWay}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <RadioButton
                                    GroupName="InspectorSectionGroup"
                                    Style="{StaticResource BatCaveInspectorTabRadioButtonStyle}"
                                    Content="Summary"
                                    IsChecked="{Binding IsSummarySectionSelected, Mode=OneWay}"
                                    Background="{Binding SummaryTabBackgroundBrush, Mode=OneWay}"
                                    Foreground="{Binding SummaryTabForegroundBrush, Mode=OneWay}"
                                    Command="{Binding SelectInspectorSectionCommand, Mode=OneWay}"
                                    CommandParameter="Summary" />
                                <RadioButton
                                    GroupName="InspectorSectionGroup"
                                    Style="{StaticResource BatCaveInspectorTabRadioButtonStyle}"
                                    Content="Performance"
                                    IsChecked="{Binding IsPerformanceSectionSelected, Mode=OneWay}"
                                    Background="{Binding PerformanceTabBackgroundBrush, Mode=OneWay}"
                                    Foreground="{Binding PerformanceTabForegroundBrush, Mode=OneWay}"
                                    Command="{Binding SelectInspectorSectionCommand, Mode=OneWay}"
                                    CommandParameter="Performance" />
                                <RadioButton
                                    GroupName="InspectorSectionGroup"
                                    Style="{StaticResource BatCaveInspectorTabRadioButtonStyle}"
                                    Content="Details"
                                    IsChecked="{Binding IsDetailsSectionSelected, Mode=OneWay}"
                                    Background="{Binding DetailsTabBackgroundBrush, Mode=OneWay}"
                                    Foreground="{Binding DetailsTabForegroundBrush, Mode=OneWay}"
                                    Command="{Binding SelectInspectorSectionCommand, Mode=OneWay}"
                                    CommandParameter="Details" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Visibility="{Binding InspectorOverviewSummaryVisibility, Mode=OneWay}" Text="{Binding InspectorOverviewSummary, Mode=OneWay}" />
                        </StackPanel>
                        <Grid x:Name="InspectorSectionHost" Grid.Row="3">
                            <Grid Visibility="{Binding SystemSummarySectionVisibility, Mode=OneWay}">
                                <Grid
                                    ColumnSpacing="14"
                                    Visibility="{Binding GlobalPerformanceContentVisibility, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="SystemSummaryPrimaryColumn" Width="*" />
                                        <ColumnDefinition x:Name="SystemSummaryStatsColumn" Width="0" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition x:Name="SystemSummaryStatsRow" Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Border
                                            Grid.Row="0"
                                            Visibility="{Binding GlobalCombinedChartVisibility, Mode=OneWay}"
                                            Background="{ThemeResource BatCavePanelAltBrush}"
                                            CornerRadius="8"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="{Binding GlobalPrimaryChartTitle, Mode=OneWay}" />
                                                    <TextBlock Style="{StaticResource BatCaveHeroValueStyle}" Text="{Binding GlobalDetailCurrentValue, Mode=OneWay}" />
                                                    <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Text="{Binding GlobalDetailSubtitle, Mode=OneWay}" />
                                                </StackPanel>
                                                <controls:MetricTrendChart
                                                    x:Name="SystemPrimaryTrendChart"
                                                    Grid.Row="1"
                                                    Margin="0,12,0,0"
                                                    MinHeight="220"
                                                    Background="Transparent"
                                                    ChartIdentityKey="{Binding SystemPrimaryChartIdentityKey, Mode=OneWay}"
                                                    Values="{Binding GlobalPrimaryTrendValues, Mode=OneWay}"
                                                    VisiblePointCount="{Binding ViewModel.MetricTrendWindowSeconds, ElementName=RootWindow, Mode=OneWay}"
                                                    OverlayValues="{Binding GlobalSecondaryTrendValues, Mode=OneWay}"
                                                    ShowOverlay="{Binding GlobalShowSecondaryOverlay, Mode=OneWay}"
                                                    ScaleMode="{Binding GlobalPrimaryScaleMode, Mode=OneWay}"
                                                    DomainMaxOverride="{Binding GlobalPrimaryDomainMax, Mode=OneWay}"
                                                    ShowGrid="True"
                                                    EnableSmoothPointTransitions="False"
                                                    AutomationProperties.Name="{Binding SystemPrimaryChartAutomationName, Mode=OneWay}"
                                                    AutomationProperties.HelpText="{Binding SystemPrimaryChartAutomationHelpText, Mode=OneWay}">
                                                    <controls:MetricTrendChart.StrokeBrush>
                                                        <SolidColorBrush Color="{Binding GlobalPrimaryStrokeColor, Mode=OneWay}" />
                                                    </controls:MetricTrendChart.StrokeBrush>
                                                    <controls:MetricTrendChart.FillBrush>
                                                        <SolidColorBrush Color="{Binding GlobalPrimaryFillColor, Mode=OneWay}" />
                                                    </controls:MetricTrendChart.FillBrush>
                                                    <controls:MetricTrendChart.OverlayStrokeBrush>
                                                        <SolidColorBrush Color="{Binding GlobalSecondaryStrokeColor, Mode=OneWay}" />
                                                    </controls:MetricTrendChart.OverlayStrokeBrush>
                                                </controls:MetricTrendChart>
                                                <Border
                                                    Grid.Row="1"
                                                    Background="Transparent"
                                                    PointerMoved="InspectorChartOverlay_PointerMoved"
                                                    PointerExited="InspectorChartOverlay_PointerExited"
                                                    Tag="SystemPrimary" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Margin="0,10,0,4"
                                                    Style="{StaticResource BatCaveMetricLabelStyle}"
                                                    Text="{Binding GlobalAuxiliaryChartTitle, Mode=OneWay}"
                                                    Visibility="{Binding GlobalAuxiliaryChartVisibility, Mode=OneWay}" />
                                                <controls:MetricTrendChart
                                                    x:Name="SystemAuxTrendChart"
                                                    Grid.Row="3"
                                                    MinHeight="72"
                                                    Background="Transparent"
                                                    Visibility="{Binding GlobalAuxiliaryChartVisibility, Mode=OneWay}"
                                                    ChartIdentityKey="{Binding SystemAuxiliaryChartIdentityKey, Mode=OneWay}"
                                                    Values="{Binding GlobalAuxiliaryTrendValues, Mode=OneWay}"
                                                    VisiblePointCount="{Binding ViewModel.MetricTrendWindowSeconds, ElementName=RootWindow, Mode=OneWay}"
                                                    ScaleMode="{Binding GlobalAuxiliaryScaleMode, Mode=OneWay}"
                                                    DomainMaxOverride="{Binding GlobalAuxiliaryDomainMax, Mode=OneWay}"
                                                    ShowGrid="False"
                                                    EnableSmoothPointTransitions="{ThemeResource BatCaveChartSmoothTransitionsEnabled}"
                                                    AutomationProperties.Name="{Binding SystemAuxiliaryChartAutomationName, Mode=OneWay}"
                                                    AutomationProperties.HelpText="{Binding SystemAuxiliaryChartAutomationHelpText, Mode=OneWay}"
                                                    ShowAreaFill="False">
                                                    <controls:MetricTrendChart.StrokeBrush>
                                                        <SolidColorBrush Color="{Binding GlobalAuxiliaryStrokeColor, Mode=OneWay}" />
                                                    </controls:MetricTrendChart.StrokeBrush>
                                                    <controls:MetricTrendChart.FillBrush>
                                                        <SolidColorBrush Color="{Binding GlobalAuxiliaryFillColor, Mode=OneWay}" />
                                                    </controls:MetricTrendChart.FillBrush>
                                                </controls:MetricTrendChart>
                                                <Border
                                                    Grid.Row="3"
                                                    Background="Transparent"
                                                    Visibility="{Binding GlobalAuxiliaryChartVisibility, Mode=OneWay}"
                                                    PointerMoved="InspectorChartOverlay_PointerMoved"
                                                    PointerExited="InspectorChartOverlay_PointerExited"
                                                    Tag="SystemAuxiliary" />
                                            </Grid>
                                        </Border>

                                        <Border
                                            x:Name="GlobalCpuLogicalGridHost"
                                            Grid.Row="0"
                                            Background="{ThemeResource BatCavePanelAltBrush}"
                                            CornerRadius="8"
                                            Padding="12"
                                            Visibility="{Binding GlobalCpuLogicalGridVisibility, Mode=OneWay}"
                                            SizeChanged="GlobalCpuLogicalGridHost_SizeChanged"
                                            VerticalAlignment="Stretch">
                                            <ScrollViewer
                                                x:Name="GlobalCpuLogicalGridScroller"
                                                HorizontalScrollBarVisibility="Disabled"
                                                HorizontalScrollMode="Disabled"
                                                VerticalScrollBarVisibility="Auto"
                                                VerticalScrollMode="Auto">
                                                <ItemsRepeater
                                                    x:Name="GlobalCpuLogicalRepeater"
                                                    ItemsSource="{Binding GlobalCpuLogicalProcessorRows, Mode=OneWay}">
                                                    <ItemsRepeater.Layout>
                                                        <UniformGridLayout
                                                            x:Name="GlobalCpuLogicalUniformLayout"
                                                            MinColumnSpacing="4"
                                                            MinItemHeight="72"
                                                            MinItemWidth="140"
                                                            MinRowSpacing="4"
                                                            Orientation="Horizontal" />
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid
                                                                x:Name="LogicalCpuTileRoot"
                                                                RowSpacing="2">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="{Binding Title, Mode=OneWay}" />
                                                                <controls:MetricTrendChart
                                                                    x:Name="LogicalCpuTrendChart"
                                                                    Grid.Row="1"
                                                                    MinHeight="18"
                                                                    Background="Transparent"
                                                                    ChartIdentityKey="{Binding ChartIdentityKey, Mode=OneWay}"
                                                                    Values="{Binding Values, Mode=OneWay}"
                                                                    VisiblePointCount="{Binding ViewModel.MetricTrendWindowSeconds, ElementName=RootWindow, Mode=OneWay}"
                                                                    OverlayValues="{Binding OverlayValues, Mode=OneWay}"
                                                                    ShowOverlay="True"
                                                                    ScaleMode="CpuPercent"
                                                                    StrokeBrush="{ThemeResource ChartCpuStrokeBrush}"
                                                                    FillBrush="{ThemeResource ChartCpuFillBrush}"
                                                                    OverlayStrokeBrush="{ThemeResource ChartCpuKernelStrokeBrush}"
                                                                    ShowGrid="True"
                                                                    EnableSmoothPointTransitions="{ThemeResource BatCaveChartSmoothTransitionsEnabled}"
                                                                    AutomationProperties.Name="{Binding LogicalChartAutomationName, Mode=OneWay}"
                                                                    AutomationProperties.HelpText="{Binding LogicalChartAutomationHelpText, Mode=OneWay}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>

                                    <StackPanel x:Name="SystemSummaryStatsPanel" Grid.Column="1" Spacing="10">
                                        <TextBlock Style="{StaticResource BatCaveEyebrowTextStyle}" Text="KEY STATS" />
                                        <ItemsControl ItemsSource="{Binding SummaryStatCards, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border MinWidth="208" MaxWidth="{Binding ViewModel.SummaryStatCardWidth, ElementName=RootWindow, Mode=OneWay}" Margin="0,0,0,10" Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="12">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="{Binding Label, Mode=OneWay}" />
                                                            <TextBlock Style="{StaticResource BatCaveMetricValueStyle}" Text="{Binding Value, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                                <Grid Visibility="{Binding GlobalPerformanceSkeletonVisibility, Mode=OneWay}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border
                                        Grid.Row="0"
                                        Background="{ThemeResource BatCavePanelAltBrush}"
                                        CornerRadius="8"
                                        Padding="16">
                                        <Grid RowSpacing="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Spacing="8">
                                                <Border Width="160" Height="14" Background="{ThemeResource BatCaveMutedBrush}" CornerRadius="6" />
                                                <Border Width="220" Height="28" Background="{ThemeResource BatCaveMutedBrush}" CornerRadius="6" />
                                                <Border Width="180" Height="12" Background="{ThemeResource BatCaveMutedBrush}" CornerRadius="6" />
                                            </StackPanel>
                                            <Border Grid.Row="1" MinHeight="220" Background="{ThemeResource BatCaveMutedBrush}" CornerRadius="8" />
                                            <Border Grid.Row="2" Height="72" Background="{ThemeResource BatCaveMutedBrush}" CornerRadius="8" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,14,0,0" Spacing="10">
                                        <TextBlock Style="{StaticResource BatCaveEyebrowTextStyle}" Text="KEY STATS" />
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" MinHeight="88" Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" />
                                            <Border Grid.Column="1" MinHeight="88" Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <Grid Visibility="{Binding ProcessSummarySectionVisibility, Mode=OneWay}" RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" VerticalAlignment="Stretch">
                                    <Border
                                        Visibility="{Binding GlobalCombinedChartVisibility, Mode=OneWay}"
                                        Background="{ThemeResource BatCavePanelAltBrush}"
                                        CornerRadius="8"
                                        Padding="14"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="{Binding GlobalPrimaryChartTitle, Mode=OneWay}" />
                                                <TextBlock Style="{StaticResource BatCaveHeroValueStyle}" Text="{Binding GlobalDetailCurrentValue, Mode=OneWay}" />
                                                <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Text="{Binding GlobalDetailSubtitle, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart
                                                x:Name="ProcessPrimaryTrendChart"
                                                Grid.Row="1"
                                                Margin="0,12,0,0"
                                                MinHeight="240"
                                                VerticalAlignment="Stretch"
                                                Background="Transparent"
                                                ChartIdentityKey="{Binding ProcessPrimaryChartIdentityKey, Mode=OneWay}"
                                                Values="{Binding GlobalPrimaryTrendValues, Mode=OneWay}"
                                                VisiblePointCount="{Binding ViewModel.MetricTrendWindowSeconds, ElementName=RootWindow, Mode=OneWay}"
                                                OverlayValues="{Binding GlobalSecondaryTrendValues, Mode=OneWay}"
                                                ShowOverlay="{Binding GlobalShowSecondaryOverlay, Mode=OneWay}"
                                                ScaleMode="{Binding GlobalPrimaryScaleMode, Mode=OneWay}"
                                                DomainMaxOverride="{Binding GlobalPrimaryDomainMax, Mode=OneWay}"
                                                ShowGrid="True"
                                                EnableSmoothPointTransitions="False"
                                                AutomationProperties.Name="{Binding ProcessPrimaryChartAutomationName, Mode=OneWay}"
                                                AutomationProperties.HelpText="{Binding ProcessPrimaryChartAutomationHelpText, Mode=OneWay}">
                                                <controls:MetricTrendChart.StrokeBrush>
                                                    <SolidColorBrush Color="{Binding GlobalPrimaryStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.StrokeBrush>
                                                <controls:MetricTrendChart.FillBrush>
                                                    <SolidColorBrush Color="{Binding GlobalPrimaryFillColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.FillBrush>
                                                <controls:MetricTrendChart.OverlayStrokeBrush>
                                                    <SolidColorBrush Color="{Binding GlobalSecondaryStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.OverlayStrokeBrush>
                                            </controls:MetricTrendChart>
                                            <Border
                                                Grid.Row="1"
                                                Background="Transparent"
                                                PointerMoved="InspectorChartOverlay_PointerMoved"
                                                PointerExited="InspectorChartOverlay_PointerExited"
                                                Tag="ProcessPrimary" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        x:Name="ProcessLogicalPlaceholder"
                                        Visibility="{Binding GlobalCpuLogicalPlaceholderVisibility, Mode=OneWay}"
                                        Background="{ThemeResource BatCavePanelAltBrush}"
                                        CornerRadius="8"
                                        Padding="18"
                                        MinHeight="180"
                                        VerticalAlignment="Stretch">
                                        <StackPanel Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="LOGICAL CPU VIEW UNAVAILABLE" />
                                            <TextBlock Style="{StaticResource BatCaveMetricValueStyle}" Text="Logical processor breakdown is only available in System Overview." TextWrapping="WrapWholeWords" />
                                            <TextBlock Style="{StaticResource BatCaveSectionSubtitleStyle}" Text="Switch back to Combined or clear the process selection to view it." TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ScrollViewer
                                    x:Name="ProcessSummaryContentScroller"
                                    Grid.Row="1"
                                    VerticalScrollBarVisibility="Auto"
                                    VerticalScrollMode="Auto">
                                    <StackPanel Spacing="14">
                                        <Border
                                            Background="{ThemeResource BatCavePanelAltBrush}"
                                            CornerRadius="8"
                                            Padding="12">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="6">
                                                    <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="METADATA STATUS" />
                                                    <TextBlock Foreground="{ThemeResource BatCaveTextPrimaryBrush}" Text="{Binding MetadataStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="6">
                                                    <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="EXECUTABLE" />
                                                    <TextBlock Foreground="{ThemeResource BatCaveTextPrimaryBrush}" Text="{Binding DetailsPanePrimaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>

                            <ScrollViewer Visibility="{Binding PerformanceSectionVisibility, Mode=OneWay}">
                                <StackPanel Spacing="16">
                                    <TextBlock Style="{StaticResource BatCaveSectionTitleStyle}" Text="Performance Breakdown" />
                                    <ItemsControl ItemsSource="{Binding GlobalDetailStats, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="240" Margin="0,0,12,10" Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="12">
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="{Binding Label, Mode=OneWay}" />
                                                        <TextBlock Style="{StaticResource BatCaveMetricValueStyle}" Text="{Binding Value, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <ScrollViewer Visibility="{Binding DetailsSectionVisibility, Mode=OneWay}">
                                <StackPanel Spacing="14">
                                    <TextBlock Style="{StaticResource BatCaveSectionTitleStyle}" Text="{Binding DetailsPaneTitle, Mode=OneWay}" />
                                    <Border Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="PRIMARY" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextPrimaryBrush}" Text="{Binding DetailsPanePrimaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="SECONDARY" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextPrimaryBrush}" Text="{Binding DetailsPaneSecondaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{ThemeResource BatCavePanelAltBrush}" CornerRadius="8" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="METADATA STATUS" />
                                            <TextBlock Style="{StaticResource BatCaveMetricValueStyle}" Text="{Binding MetadataStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Style="{StaticResource BatCaveMetricLabelStyle}" Text="PARENT PID" />
                                            <TextBlock Style="{StaticResource BatCaveMetricValueStyle}" Text="{Binding MetadataParentPid, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border
            Grid.Row="3"
            Background="{ThemeResource BatCaveHeaderBrush}"
            Padding="{ThemeResource ShellFooterPadding}">
            <controls:RuntimeStatusFooter DataContext="{x:Bind ViewModel, Mode=OneWay}" />
        </Border>
    </Grid>
</Window>

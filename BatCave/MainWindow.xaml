<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BatCave.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:BatCave.Controls"
    xmlns:charts="using:BatCave.Charts"
    xmlns:viewModels="using:BatCave.ViewModels"
    mc:Ignorable="d"
    Title="BatCave">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FocusFilterAccelerator_Invoked" />
            <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="RetryAccelerator_Invoked" />
            <KeyboardAccelerator Key="L" Modifiers="Control" Invoked="ClearSelectionAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="16"
            BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="BatCave Monitor" />
                <TextBlock Opacity="0.8" Text="Windows-native process telemetry with runtime parity." />
                <TextBox
                    x:Name="FilterTextBox"
                    AccessKey="F"
                    AutomationProperties.HelpText="Type to filter by process name or process id."
                    AutomationProperties.Name="Process Filter"
                    PlaceholderText="Filter by name or PID"
                    TabIndex="1"
                    Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ToggleSwitch
                        x:Name="AdminModeToggle"
                        AccessKey="A"
                        AutomationProperties.HelpText="Toggle elevated bridge mode."
                        AutomationProperties.Name="Admin Mode Toggle"
                        Header="Admin Mode"
                        IsOn="{x:Bind ViewModel.AdminModeEnabled, Mode=OneWay}"
                        TabIndex="2"
                        Toggled="AdminModeToggle_Toggled" />
                    <CheckBox
                        AccessKey="E"
                        AutomationProperties.HelpText="Show only processes with full access when admin mode is enabled."
                        AutomationProperties.Name="Admin Enabled Only Filter"
                        TabIndex="3"
                        VerticalAlignment="Center"
                        Content="Admin-enabled only"
                        IsChecked="{x:Bind ViewModel.AdminEnabledOnlyFilter, Mode=TwoWay}"
                        IsEnabled="{x:Bind ViewModel.AdminModeEnabled, Mode=OneWay}" />
                </StackPanel>
                <TextBlock
                    AutomationProperties.LiveSetting="Assertive"
                    AutomationProperties.Name="Runtime Warning Banner"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Text="{x:Bind ViewModel.AdminModeError, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind ViewModel.AdminErrorVisibility, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Padding="16">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}">
                <ProgressRing IsActive="True" />
                <TextBlock Text="Starting monitoring runtime..." />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.BlockedVisibility, Mode=OneWay}">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Startup Blocked" />
                <TextBlock MaxWidth="760" Text="{x:Bind ViewModel.BlockedReasonMessage, Mode=OneWay}" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.StartupErrorVisibility, Mode=OneWay}">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Startup Error" />
                <TextBlock MaxWidth="760" Text="{x:Bind ViewModel.StartupErrorMessage, Mode=OneWay}" TextWrapping="Wrap" />
                <Button
                    x:Name="RetryBootstrapButton"
                    AccessKey="R"
                    AutomationProperties.HelpText="Retry startup after an error."
                    AutomationProperties.Name="Retry Startup"
                    Click="RetryBootstrap_Click"
                    Content="Retry"
                    TabIndex="4" />
            </StackPanel>

            <Grid Visibility="{x:Bind ViewModel.LiveVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,8" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="1.3*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" AccessKey="N" AutomationProperties.Name="Sort by name" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="Name" Content="{x:Bind ViewModel.NameSortLabel, Mode=OneWay}" TabIndex="10">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="N" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button Grid.Column="1" AccessKey="P" AutomationProperties.Name="Sort by process identifier" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="Pid" Content="{x:Bind ViewModel.PidSortLabel, Mode=OneWay}" TabIndex="11">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="P" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button Grid.Column="2" AccessKey="U" AutomationProperties.Name="Sort by cpu usage" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="CpuPct" Content="{x:Bind ViewModel.CpuSortLabel, Mode=OneWay}" TabIndex="12">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="U" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button Grid.Column="3" AccessKey="M" AutomationProperties.Name="Sort by memory usage" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="RssBytes" Content="{x:Bind ViewModel.MemorySortLabel, Mode=OneWay}" TabIndex="13">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="M" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button Grid.Column="4" AccessKey="D" AutomationProperties.Name="Sort by disk read rate" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="IoReadBps" Content="{x:Bind ViewModel.IoReadSortLabel, Mode=OneWay}" TabIndex="14">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="D" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button Grid.Column="5" AccessKey="W" AutomationProperties.Name="Sort by disk write rate" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="IoWriteBps" Content="{x:Bind ViewModel.IoWriteSortLabel, Mode=OneWay}" TabIndex="15">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="W" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button Grid.Column="6" AccessKey="O" AutomationProperties.Name="Sort by other input output transfer rate" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="OtherIoBps" Content="{x:Bind ViewModel.OtherIoSortLabel, Mode=OneWay}" TabIndex="16">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="O" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button Grid.Column="7" AccessKey="T" AutomationProperties.Name="Sort by thread count" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="Threads" Content="{x:Bind ViewModel.ThreadsSortLabel, Mode=OneWay}" TabIndex="17">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="T" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button Grid.Column="8" AccessKey="H" AutomationProperties.Name="Sort by handle count" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" Command="{x:Bind ViewModel.SortHeaderCommand}" CommandParameter="Handles" Content="{x:Bind ViewModel.HandlesSortLabel, Mode=OneWay}" TabIndex="18">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="H" Modifiers="Control,Shift" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <TextBlock Grid.Column="9" VerticalAlignment="Center" FontWeight="SemiBold" Text="CPU Trend" />
                        </Grid>

                        <ListView
                            x:Name="ProcessListView"
                            AutomationProperties.HelpText="Process table. Use arrow keys to move selection."
                            AutomationProperties.Name="Process Table"
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.VisibleRows, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedVisibleRowBinding, Mode=OneWay}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectionChanged="ProcessListView_SelectionChanged"
                            SelectionMode="Single"
                            TabIndex="19">
                            <ListView.Resources>
                                <StaticResource x:Key="ListViewItemBackgroundSelected" ResourceKey="AccentFillColorSecondaryBrush" />
                                <StaticResource x:Key="ListViewItemBackgroundSelectedPointerOver" ResourceKey="AccentFillColorDefaultBrush" />
                                <StaticResource x:Key="ListViewItemBackgroundSelectedPressed" ResourceKey="AccentFillColorTertiaryBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelected" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelectedPointerOver" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelectedPressed" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorBrush" ResourceKey="AccentFillColorDefaultBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorPointerOverBrush" ResourceKey="AccentFillColorDefaultBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorPressedBrush" ResourceKey="AccentFillColorDefaultBrush" />
                                <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">True</x:Boolean>
                            </ListView.Resources>
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MinHeight" Value="30" />
                                    <Setter Property="Padding" Value="3,2" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ProcessRowViewState">
                                    <Grid Padding="2,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1.3*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind Pid, Mode=OneWay}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="2" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind CpuText, Mode=OneWay}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="3" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind RssText, Mode=OneWay}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="4" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind IoReadText, Mode=OneWay}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="5" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind IoWriteText, Mode=OneWay}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="6" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind OtherIoText, Mode=OneWay}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="7" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind Threads, Mode=OneWay}" TextAlignment="Right" />
                                        <TextBlock Grid.Column="8" FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind Handles, Mode=OneWay}" TextAlignment="Right" />
                                        <Canvas Grid.Column="9" Width="96" Height="22" HorizontalAlignment="Stretch" IsTabStop="False">
                                            <Polyline
                                                Points="{x:Bind charts:SparklineMath.ToPointCollection(CpuTrendGeometry), Mode=OneWay}"
                                                Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                StrokeLineJoin="Round"
                                                StrokeStartLineCap="Round"
                                                StrokeEndLineCap="Round"
                                                StrokeThickness="2.5" />
                                        </Canvas>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid>
                        <Grid x:Name="ProcessDetailRoot" Visibility="{x:Bind ViewModel.ProcessDetailVisibility, Mode=OneWay}" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" HorizontalAlignment="Stretch" Spacing="10">
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.DetailTitle, Mode=OneWay}" />
                                <Button
                                    x:Name="ClearSelectionButton"
                                    AccessKey="L"
                                    AutomationProperties.Name="Clear process selection"
                                    Command="{x:Bind ViewModel.ClearSelectionRequestedCommand}"
                                    Content="Clear Selection"
                                    IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                                    TabIndex="20" />
                            </StackPanel>

                            <Grid x:Name="MetricTrendSplitGrid" Grid.Row="1" ColumnSpacing="6" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="MetricSidebarColumn" Width="*" />
                                    <ColumnDefinition x:Name="MetricMainColumn" Width="0" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition x:Name="MetricSidebarRow" Height="Auto" />
                                    <RowDefinition x:Name="MetricMainRow" Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel x:Name="MetricSidebarHost" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Metric Trends" />

                                    <ToggleButton
                                        AccessKey="1"
                                        AutomationProperties.Name="Focus cpu metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsCpuMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="Cpu"
                                        TabIndex="30">
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number1" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="CPU" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.CpuMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart x:Name="CpuChipPlot" Grid.Column="1" MinWidth="120" Height="36" HorizontalAlignment="Stretch" Background="Transparent" IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton
                                        AccessKey="2"
                                        AutomationProperties.Name="Focus memory metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsMemoryMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="Memory"
                                        TabIndex="31">
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number2" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Memory" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.MemoryMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart x:Name="MemoryChipPlot" Grid.Column="1" MinWidth="120" Height="36" HorizontalAlignment="Stretch" Background="Transparent" IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton
                                        AccessKey="3"
                                        AutomationProperties.Name="Focus disk read metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsIoReadMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="IoRead"
                                        TabIndex="32">
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number3" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Disk Read" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.IoReadMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart x:Name="IoReadChipPlot" Grid.Column="1" MinWidth="120" Height="36" HorizontalAlignment="Stretch" Background="Transparent" IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton
                                        AccessKey="4"
                                        AutomationProperties.Name="Focus disk write metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsIoWriteMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="IoWrite"
                                        TabIndex="33">
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number4" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Disk Write" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.IoWriteMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart x:Name="IoWriteChipPlot" Grid.Column="1" MinWidth="120" Height="36" HorizontalAlignment="Stretch" Background="Transparent" IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton
                                        AccessKey="5"
                                        AutomationProperties.Name="Focus other input output metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsOtherIoMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="OtherIo"
                                        TabIndex="34">
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number5" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Other I/O" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.OtherIoMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart x:Name="OtherIoChipPlot" Grid.Column="1" MinWidth="120" Height="36" HorizontalAlignment="Stretch" Background="Transparent" IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>
                                </StackPanel>

                                <Border
                                    x:Name="MetricMainHost"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Padding="10"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.ExpandedMetricTitle, Mode=OneWay}" />
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                                                <TextBlock HorizontalAlignment="Right" FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.ExpandedMetricValue, Mode=OneWay}" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                                    <ToggleButton
                                                        Content="60s"
                                                        IsChecked="{x:Bind ViewModel.IsTrendWindow60Selected, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.MetricTrendWindowSelectedCommand}"
                                                        CommandParameter="60" />
                                                    <ToggleButton
                                                        Content="120s"
                                                        IsChecked="{x:Bind ViewModel.IsTrendWindow120Selected, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.MetricTrendWindowSelectedCommand}"
                                                        CommandParameter="120" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <controls:MetricTrendChart x:Name="ExpandedMetricPlot" Grid.Row="1" MinHeight="220" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="Transparent" IsTabStop="False" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="240">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="Metadata Status" />
                                    <TextBlock Text="{x:Bind ViewModel.MetadataStatus, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock FontWeight="SemiBold" Text="Parent PID" />
                                    <TextBlock Text="{x:Bind ViewModel.MetadataParentPid, Mode=OneWay}" />
                                    <TextBlock FontWeight="SemiBold" Text="Executable Path" />
                                    <TextBlock Text="{x:Bind ViewModel.MetadataExecutablePath, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock FontWeight="SemiBold" Text="Command Line" />
                                    <TextBlock Text="{x:Bind ViewModel.MetadataCommandLine, Mode=OneWay}" TextWrapping="Wrap" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid
                            x:Name="GlobalPerformanceRoot"
                            DataContext="{x:Bind ViewModel, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.GlobalPerformanceVisibility, Mode=OneWay}"
                            ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="248" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.ColumnSpan="2" Visibility="{Binding GlobalPerformanceSkeletonVisibility, Mode=OneWay}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="248" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Padding="12"
                                    Background="{StaticResource TaskMgrPaneBackgroundBrush}"
                                    BorderBrush="{StaticResource TaskMgrPaneBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel Spacing="10">
                                        <ProgressRing IsActive="True" Width="24" Height="24" />
                                        <TextBlock Style="{StaticResource TaskMgrSectionTitleStyle}" Text="Loading system metrics..." />
                                        <Rectangle Height="18" RadiusX="3" RadiusY="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="18" RadiusX="3" RadiusY="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="18" RadiusX="3" RadiusY="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Grid.Column="1"
                                    Padding="12"
                                    Background="{StaticResource TaskMgrPaneBackgroundBrush}"
                                    BorderBrush="{StaticResource TaskMgrPaneBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel Spacing="8">
                                        <Rectangle Height="22" RadiusX="4" RadiusY="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="14" RadiusX="4" RadiusY="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="230" RadiusX="4" RadiusY="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="80" RadiusX="4" RadiusY="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ListView
                                x:Name="GlobalResourceListView"
                                Visibility="{Binding GlobalPerformanceContentVisibility, Mode=OneWay}"
                                ItemsSource="{Binding GlobalResourceRows, Mode=OneWay}"
                                SelectionChanged="GlobalResourceListView_SelectionChanged"
                                SelectionMode="Single"
                                Background="{StaticResource TaskMgrPaneBackgroundBrush}"
                                BorderBrush="{StaticResource TaskMgrPaneBorderBrush}"
                                BorderThickness="1"
                                Padding="4">
                                <ListView.Resources>
                                    <StaticResource x:Key="ListViewItemBackgroundSelected" ResourceKey="SubtleFillColorSecondaryBrush" />
                                    <StaticResource x:Key="ListViewItemBackgroundSelectedPointerOver" ResourceKey="SubtleFillColorTertiaryBrush" />
                                    <StaticResource x:Key="ListViewItemBackgroundSelectedPressed" ResourceKey="SubtleFillColorSecondaryBrush" />
                                    <StaticResource x:Key="ListViewItemForegroundSelected" ResourceKey="TextFillColorPrimaryBrush" />
                                    <StaticResource x:Key="ListViewItemForegroundSelectedPointerOver" ResourceKey="TextFillColorPrimaryBrush" />
                                    <StaticResource x:Key="ListViewItemForegroundSelectedPressed" ResourceKey="TextFillColorPrimaryBrush" />
                                    <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">False</x:Boolean>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="MinHeight" Value="{StaticResource TaskMgrDenseRowMinHeight}" />
                                        <Setter Property="Padding" Value="{StaticResource TaskMgrResourceRowPadding}" />
                                        <Setter Property="Margin" Value="0,1" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <controls:MetricTrendChart
                                                Height="34"
                                                MinWidth="84"
                                                Values="{Binding MiniTrendValues, Mode=OneWay}"
                                                ScaleMode="{Binding MiniScaleMode, Mode=OneWay}"
                                                DomainMaxOverride="{Binding MiniDomainMax, Mode=OneWay}"
                                                ShowGrid="False"
                                                IsTabStop="False"
                                                Background="Transparent">
                                                <controls:MetricTrendChart.StrokeBrush>
                                                    <SolidColorBrush Color="{Binding MiniStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.StrokeBrush>
                                                <controls:MetricTrendChart.FillBrush>
                                                    <SolidColorBrush Color="{Binding MiniFillColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.FillBrush>
                                            </controls:MetricTrendChart>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock Style="{StaticResource TaskMgrMetricLabelStyle}" Text="{Binding Title, Mode=OneWay}" />
                                                <TextBlock Style="{StaticResource TaskMgrSectionSubtitleStyle}" Text="{Binding Subtitle, Mode=OneWay}" Visibility="{Binding SubtitleVisibility, Mode=OneWay}" />
                                                <TextBlock Style="{StaticResource TaskMgrSectionSubtitleStyle}" Text="{Binding ValueText, Mode=OneWay}" Visibility="{Binding ValueVisibility, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Border
                                Grid.Column="1"
                                Visibility="{Binding GlobalPerformanceContentVisibility, Mode=OneWay}"
                                Padding="10"
                                Background="{StaticResource TaskMgrPaneBackgroundBrush}"
                                BorderBrush="{StaticResource TaskMgrPaneBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="1">
                                            <TextBlock Style="{StaticResource TaskMgrSectionTitleStyle}" Text="{Binding GlobalDetailTitle, Mode=OneWay}" />
                                            <TextBlock Style="{StaticResource TaskMgrSectionSubtitleStyle}" Text="{Binding GlobalDetailSubtitle, Mode=OneWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="4">
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                Style="{StaticResource TaskMgrMetricValueStyle}"
                                                FontSize="22"
                                                Text="{Binding GlobalDetailCurrentValue, Mode=OneWay}" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                                <ToggleButton
                                                    Content="60s"
                                                    IsChecked="{x:Bind ViewModel.IsTrendWindow60Selected, Mode=OneWay}"
                                                    Command="{x:Bind ViewModel.MetricTrendWindowSelectedCommand}"
                                                    CommandParameter="60" />
                                                <ToggleButton
                                                    Content="120s"
                                                    IsChecked="{x:Bind ViewModel.IsTrendWindow120Selected, Mode=OneWay}"
                                                    Command="{x:Bind ViewModel.MetricTrendWindowSelectedCommand}"
                                                    CommandParameter="120" />
                                                <StackPanel Orientation="Horizontal" Spacing="6" Visibility="{Binding GlobalCpuModeToggleVisibility, Mode=OneWay}">
                                                    <ToggleButton
                                                        Content="Combined"
                                                        IsChecked="{x:Bind ViewModel.IsCpuCombinedMode, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.CpuGraphModeSelectedCommand}"
                                                        CommandParameter="Combined" />
                                                    <ToggleButton
                                                        Content="Logical"
                                                        IsChecked="{x:Bind ViewModel.IsCpuLogicalMode, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.CpuGraphModeSelectedCommand}"
                                                        CommandParameter="LogicalProcessors" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="1" RowSpacing="6">
                                        <Grid Visibility="{Binding GlobalCombinedChartVisibility, Mode=OneWay}" RowSpacing="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource TaskMgrMetricLabelStyle}" Text="{Binding GlobalPrimaryChartTitle, Mode=OneWay}" />
                                            <controls:MetricTrendChart
                                                Grid.Row="1"
                                                MinHeight="220"
                                                Values="{Binding GlobalPrimaryTrendValues, Mode=OneWay}"
                                                OverlayValues="{Binding GlobalSecondaryTrendValues, Mode=OneWay}"
                                                ShowOverlay="{Binding GlobalShowSecondaryOverlay, Mode=OneWay}"
                                                ScaleMode="{Binding GlobalPrimaryScaleMode, Mode=OneWay}"
                                                DomainMaxOverride="{Binding GlobalPrimaryDomainMax, Mode=OneWay}"
                                                ShowGrid="True"
                                                IsTabStop="False"
                                                Background="Transparent">
                                                <controls:MetricTrendChart.StrokeBrush>
                                                    <SolidColorBrush Color="{Binding GlobalPrimaryStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.StrokeBrush>
                                                <controls:MetricTrendChart.FillBrush>
                                                    <SolidColorBrush Color="{Binding GlobalPrimaryFillColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.FillBrush>
                                                <controls:MetricTrendChart.OverlayStrokeBrush>
                                                    <SolidColorBrush Color="{Binding GlobalSecondaryStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.OverlayStrokeBrush>
                                            </controls:MetricTrendChart>
                                            <TextBlock
                                                Grid.Row="2"
                                                Style="{StaticResource TaskMgrMetricLabelStyle}"
                                                Text="{Binding GlobalAuxiliaryChartTitle, Mode=OneWay}"
                                                Visibility="{Binding GlobalAuxiliaryChartVisibility, Mode=OneWay}" />
                                            <controls:MetricTrendChart
                                                Grid.Row="3"
                                                MinHeight="80"
                                                Values="{Binding GlobalAuxiliaryTrendValues, Mode=OneWay}"
                                                ScaleMode="{Binding GlobalAuxiliaryScaleMode, Mode=OneWay}"
                                                DomainMaxOverride="{Binding GlobalAuxiliaryDomainMax, Mode=OneWay}"
                                                ShowGrid="False"
                                                ShowAreaFill="False"
                                                IsTabStop="False"
                                                Background="Transparent"
                                                Visibility="{Binding GlobalAuxiliaryChartVisibility, Mode=OneWay}">
                                                <controls:MetricTrendChart.StrokeBrush>
                                                    <SolidColorBrush Color="{Binding GlobalAuxiliaryStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.StrokeBrush>
                                                <controls:MetricTrendChart.FillBrush>
                                                    <SolidColorBrush Color="{Binding GlobalAuxiliaryFillColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.FillBrush>
                                            </controls:MetricTrendChart>
                                        </Grid>

                                        <GridView
                                            Visibility="{Binding GlobalCpuLogicalGridVisibility, Mode=OneWay}"
                                            ItemsSource="{Binding GlobalCpuLogicalProcessorRows, Mode=OneWay}"
                                            IsItemClickEnabled="False"
                                            SelectionMode="None"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid MaximumRowsOrColumns="4" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                            <GridView.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Width="190" Spacing="4">
                                                        <TextBlock Style="{StaticResource TaskMgrMetricLabelStyle}" Text="{Binding Title, Mode=OneWay}" />
                                                        <controls:MetricTrendChart
                                                            Height="120"
                                                            Values="{Binding Values, Mode=OneWay}"
                                                            ScaleMode="CpuPercent"
                                                            StrokeBrush="#FF0B84D8"
                                                            FillBrush="#330B84D8"
                                                            ShowGrid="True"
                                                            IsTabStop="False"
                                                            Background="Transparent" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>
                                    </Grid>

                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding GlobalDetailStats, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="10" Margin="0,0,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource TaskMgrSectionSubtitleStyle}" Text="{Binding Label, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Right"
                                                        TextAlignment="Right"
                                                        Style="{StaticResource TaskMgrMetricValueStyle}"
                                                        Text="{Binding Value, Mode=OneWay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>

        <Border
            Grid.Row="2"
            Padding="12"
            BorderThickness="0,1,0,0">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="Runtime Health:" />
                    <TextBlock
                        AutomationProperties.LiveSetting="Polite"
                        AutomationProperties.Name="Runtime Health Status"
                        Text="{x:Bind ViewModel.RuntimeHealthStatus, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock
                    AutomationProperties.LiveSetting="Polite"
                    AutomationProperties.Name="Interaction Timing Probe"
                    FontFamily="Cascadia Mono"
                    Opacity="0.8"
                    Text="{x:Bind ViewModel.InteractionTimingProbe, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</Window>




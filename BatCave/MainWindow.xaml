<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BatCave.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:BatCave.Controls"
    xmlns:viewModels="using:BatCave.ViewModels"
    mc:Ignorable="d"
    Title="BatCave">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="ShellRoot">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FocusFilterAccelerator_Invoked" />
            <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="RetryAccelerator_Invoked" />
            <KeyboardAccelerator Key="L" Modifiers="Control" Invoked="ClearSelectionAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowWidthStates">
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderRegion.Padding" Value="16" />
                        <Setter Target="ContentRegion.Padding" Value="16" />
                        <Setter Target="FooterRegion.Padding" Value="12" />
                        <Setter Target="HeaderControlsInline.Visibility" Value="Visible" />
                        <Setter Target="HeaderControlsPhone.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="760" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderRegion.Padding" Value="12" />
                        <Setter Target="ContentRegion.Padding" Value="12" />
                        <Setter Target="FooterRegion.Padding" Value="10" />
                        <Setter Target="HeaderControlsInline.Visibility" Value="Visible" />
                        <Setter Target="HeaderControlsPhone.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="PhoneState">
                    <VisualState.Setters>
                        <Setter Target="HeaderRegion.Padding" Value="8" />
                        <Setter Target="ContentRegion.Padding" Value="8" />
                        <Setter Target="FooterRegion.Padding" Value="8" />
                        <Setter Target="HeaderControlsInline.Visibility" Value="Collapsed" />
                        <Setter Target="HeaderControlsPhone.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            x:Name="HeaderRegion"
            Grid.Row="0"
            Padding="{ThemeResource ShellHeaderPadding}"
            BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="{ThemeResource ShellTitleText}" />
                <TextBlock Opacity="0.8" Text="{ThemeResource ShellSubtitleText}" />
                <Grid x:Name="HeaderControlsInline" ColumnSpacing="12" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="FilterTextBox"
                        Grid.Column="0"
                        Width="420"
                        MinWidth="280"
                        MaxWidth="520"
                        HorizontalAlignment="Left"
                        AccessKey="F"
                        AutomationProperties.HelpText="{ThemeResource ProcessFilterHelpText}"
                        AutomationProperties.Name="Process Filter"
                        PlaceholderText="{ThemeResource FilterPlaceholderText}"
                        TabIndex="1"
                        Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" Text="Admin Mode" />
                        <ToggleSwitch
                            x:Name="AdminModeToggle"
                            AccessKey="A"
                            AutomationProperties.HelpText="{ThemeResource AdminToggleHelpText}"
                            AutomationProperties.Name="Admin Mode Toggle"
                            Header=""
                            OnContent=""
                            OffContent=""
                            IsOn="{x:Bind ViewModel.AdminModeEnabled, Mode=OneWay}"
                            TabIndex="2"
                            Toggled="AdminModeToggle_Toggled" />
                    </StackPanel>
                </Grid>
                <Grid x:Name="HeaderControlsPhone" RowSpacing="8" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox
                        x:Name="FilterTextBoxPhone"
                        AccessKey="F"
                        AutomationProperties.HelpText="{ThemeResource ProcessFilterHelpText}"
                        AutomationProperties.Name="Process Filter"
                        PlaceholderText="{ThemeResource FilterPlaceholderText}"
                        TabIndex="1"
                        Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
                        <TextBlock VerticalAlignment="Center" Text="Admin Mode" />
                        <ToggleSwitch
                            x:Name="AdminModeTogglePhone"
                            AccessKey="A"
                            AutomationProperties.HelpText="{ThemeResource AdminToggleHelpText}"
                            AutomationProperties.Name="Admin Mode Toggle"
                            Header=""
                            OnContent=""
                            OffContent=""
                            IsOn="{x:Bind ViewModel.AdminModeEnabled, Mode=OneWay}"
                            TabIndex="2"
                            Toggled="AdminModeToggle_Toggled" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid x:Name="ContentRegion" Grid.Row="1" Padding="{ThemeResource ShellContentPadding}">
            <controls:StartupStatePanel DataContext="{x:Bind ViewModel, Mode=OneWay}" />

            <Grid Visibility="{x:Bind ViewModel.LiveVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid
                            Grid.Row="0"
                            Margin="0,0,0,8"
                            ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Grid.Column="0"
                                AccessKey="N"
                                AutomationProperties.Name="Compact sort by name"
                                AutomationProperties.HelpText="Sort compact table by process name."
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                CommandParameter="Name"
                                Background="{x:Bind ViewModel.CompactNameColumnBackground, Mode=OneWay}"
                                Foreground="{x:Bind ViewModel.CompactNameSortForeground, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                TabIndex="10">
                                <StackPanel Spacing="1">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.CompactNameSortLabel, Mode=OneWay}" />
                                    <TextBlock FontSize="11" Opacity="0.8" Text="{x:Bind ViewModel.CompactNameTotalLabel, Mode=OneWay}" />
                                </StackPanel>
                            </Button>

                            <Button
                                Grid.Column="1"
                                AccessKey="U"
                                AutomationProperties.Name="Compact sort by cpu"
                                AutomationProperties.HelpText="Sort compact table by CPU usage."
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                CommandParameter="CpuPct"
                                Background="{x:Bind ViewModel.CompactCpuColumnBackground, Mode=OneWay}"
                                Foreground="{x:Bind ViewModel.CompactCpuSortForeground, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Right"
                                TabIndex="11">
                                <StackPanel Spacing="1">
                                    <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{x:Bind ViewModel.CompactCpuSortLabel, Mode=OneWay}" />
                                    <TextBlock HorizontalAlignment="Right" FontSize="11" Opacity="0.8" Text="{x:Bind ViewModel.CompactCpuTotalLabel, Mode=OneWay}" />
                                </StackPanel>
                            </Button>

                            <Button
                                Grid.Column="2"
                                AccessKey="M"
                                AutomationProperties.Name="Compact sort by memory"
                                AutomationProperties.HelpText="Sort compact table by memory usage."
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                CommandParameter="RssBytes"
                                Background="{x:Bind ViewModel.CompactMemoryColumnBackground, Mode=OneWay}"
                                Foreground="{x:Bind ViewModel.CompactMemorySortForeground, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Right"
                                TabIndex="12">
                                <StackPanel Spacing="1">
                                    <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{x:Bind ViewModel.CompactMemorySortLabel, Mode=OneWay}" />
                                    <TextBlock HorizontalAlignment="Right" FontSize="11" Opacity="0.8" Text="{x:Bind ViewModel.CompactMemoryTotalLabel, Mode=OneWay}" />
                                </StackPanel>
                            </Button>

                            <Button
                                Grid.Column="3"
                                AccessKey="D"
                                AutomationProperties.Name="Compact sort by disk"
                                AutomationProperties.HelpText="Sort compact table by disk throughput."
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                CommandParameter="DiskBps"
                                Background="{x:Bind ViewModel.CompactDiskColumnBackground, Mode=OneWay}"
                                Foreground="{x:Bind ViewModel.CompactDiskSortForeground, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Right"
                                TabIndex="13">
                                <StackPanel Spacing="1">
                                    <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{x:Bind ViewModel.CompactDiskSortLabel, Mode=OneWay}" />
                                    <TextBlock HorizontalAlignment="Right" FontSize="11" Opacity="0.8" Text="{x:Bind ViewModel.CompactDiskTotalLabel, Mode=OneWay}" />
                                </StackPanel>
                            </Button>

                            <Button
                                Grid.Column="4"
                                AccessKey="O"
                                AutomationProperties.Name="Compact sort by network"
                                AutomationProperties.HelpText="Sort compact table by network throughput."
                                Command="{x:Bind ViewModel.CompactSortHeaderCommand}"
                                CommandParameter="OtherIoBps"
                                Background="{x:Bind ViewModel.CompactNetworkColumnBackground, Mode=OneWay}"
                                Foreground="{x:Bind ViewModel.CompactNetworkSortForeground, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Right"
                                TabIndex="14">
                                <StackPanel Spacing="1">
                                    <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{x:Bind ViewModel.CompactNetworkSortLabel, Mode=OneWay}" />
                                    <TextBlock HorizontalAlignment="Right" FontSize="11" Opacity="0.8" Text="{x:Bind ViewModel.CompactNetworkTotalLabel, Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <ListView
                            x:Name="CompactProcessListView"
                            AutomationProperties.HelpText="Compact process table with name, CPU, memory, disk, and network columns."
                            AutomationProperties.Name="Compact Process Table"
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.VisibleRows, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedVisibleRowBinding, Mode=OneWay}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectionChanged="ProcessListView_SelectionChanged"
                            SelectionMode="Single"
                            TabIndex="19"
                            Background="Transparent">
                            <ListView.Resources>
                                <StaticResource x:Key="ListViewItemBackgroundSelected" ResourceKey="AccentFillColorDefaultBrush" />
                                <StaticResource x:Key="ListViewItemBackgroundSelectedPointerOver" ResourceKey="AccentFillColorDefaultBrush" />
                                <StaticResource x:Key="ListViewItemBackgroundSelectedPressed" ResourceKey="AccentFillColorSecondaryBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelected" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelectedPointerOver" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
                                <StaticResource x:Key="ListViewItemForegroundSelectedPressed" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorBrush" ResourceKey="AccentFillColorDefaultBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorPointerOverBrush" ResourceKey="AccentFillColorDefaultBrush" />
                                <StaticResource x:Key="ListViewItemSelectionIndicatorPressedBrush" ResourceKey="AccentFillColorDefaultBrush" />
                                <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">True</x:Boolean>
                            </ListView.Resources>
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MinHeight" Value="30" />
                                    <Setter Property="Padding" Value="3,2" />
                                    <Setter Property="Margin" Value="0,1" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ProcessRowViewState">
                                    <Grid Padding="2,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Padding="2,0" Background="{Binding ViewModel.CompactNameColumnBackground, ElementName=RootWindow}">
                                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                        <Border Grid.Column="1" Padding="2,0" Background="{Binding ViewModel.CompactCpuColumnBackground, ElementName=RootWindow}">
                                            <TextBlock FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind CpuText, Mode=OneWay}" TextAlignment="Right" />
                                        </Border>
                                        <Border Grid.Column="2" Padding="2,0" Background="{Binding ViewModel.CompactMemoryColumnBackground, ElementName=RootWindow}">
                                            <TextBlock FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind RssText, Mode=OneWay}" TextAlignment="Right" />
                                        </Border>
                                        <Border Grid.Column="3" Padding="2,0" Background="{Binding ViewModel.CompactDiskColumnBackground, ElementName=RootWindow}">
                                            <TextBlock FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind DiskText, Mode=OneWay}" TextAlignment="Right" />
                                        </Border>
                                        <Border Grid.Column="4" Padding="2,0" Background="{Binding ViewModel.CompactNetworkColumnBackground, ElementName=RootWindow}">
                                            <TextBlock FontFamily="Cascadia Mono" HorizontalAlignment="Right" Text="{x:Bind NetworkText, Mode=OneWay}" TextAlignment="Right" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid>
                        <Grid x:Name="ProcessDetailRoot" Visibility="{x:Bind ViewModel.ProcessDetailVisibility, Mode=OneWay}" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.DetailTitle, Mode=OneWay}" />
                                <CommandBar
                                    Grid.Row="1"
                                    DefaultLabelPosition="Right"
                                    IsOpen="False">
                                    <AppBarButton
                                        x:Name="ClearSelectionButton"
                                        AccessKey="L"
                                        AutomationProperties.Name="Clear process selection"
                                        Command="{x:Bind ViewModel.ClearSelectionRequestedCommand}"
                                        IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                                        Label="Clear Selection"
                                        TabIndex="20">
                                        <AppBarButton.Icon>
                                            <SymbolIcon Symbol="ClearSelection" />
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                </CommandBar>
                            </Grid>

                            <Grid x:Name="MetricTrendSplitGrid" Grid.Row="1" ColumnSpacing="6" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="MetricSidebarColumn" Width="*" />
                                    <ColumnDefinition x:Name="MetricMainColumn" Width="0" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition x:Name="MetricSidebarRow" Height="Auto" />
                                    <RowDefinition x:Name="MetricMainRow" Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel x:Name="MetricSidebarHost" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Metric Trends" />

                                    <ToggleButton
                                        AccessKey="1"
                                        AutomationProperties.Name="Focus cpu metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsCpuMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="Cpu"
                                        TabIndex="30">
                                        <ToggleButton.Resources>
                                            <StaticResource x:Key="ToggleButtonBackgroundChecked" ResourceKey="BalancedSelectionBackgroundBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPointerOver" ResourceKey="BalancedSelectionBackgroundPointerOverBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPressed" ResourceKey="BalancedSelectionBackgroundPressedBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundChecked" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPointerOver" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPressed" ResourceKey="BalancedSelectionForegroundBrush" />
                                        </ToggleButton.Resources>
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number1" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="CPU" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.CpuMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart
                                                x:Name="CpuChipPlot"
                                                Grid.Column="1"
                                                MinWidth="120"
                                                Height="36"
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="CPU metric trend chart"
                                                AutomationProperties.HelpText="Small CPU trend chart for selected process."
                                                Background="Transparent"
                                                IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton
                                        AccessKey="2"
                                        AutomationProperties.Name="Focus memory metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsMemoryMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="Memory"
                                        TabIndex="31">
                                        <ToggleButton.Resources>
                                            <StaticResource x:Key="ToggleButtonBackgroundChecked" ResourceKey="BalancedSelectionBackgroundBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPointerOver" ResourceKey="BalancedSelectionBackgroundPointerOverBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPressed" ResourceKey="BalancedSelectionBackgroundPressedBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundChecked" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPointerOver" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPressed" ResourceKey="BalancedSelectionForegroundBrush" />
                                        </ToggleButton.Resources>
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number2" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Memory" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.MemoryMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart
                                                x:Name="MemoryChipPlot"
                                                Grid.Column="1"
                                                MinWidth="120"
                                                Height="36"
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="Memory metric trend chart"
                                                AutomationProperties.HelpText="Small memory trend chart for selected process."
                                                Background="Transparent"
                                                IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton
                                        AccessKey="3"
                                        AutomationProperties.Name="Focus disk read metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsIoReadMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="IoRead"
                                        TabIndex="32">
                                        <ToggleButton.Resources>
                                            <StaticResource x:Key="ToggleButtonBackgroundChecked" ResourceKey="BalancedSelectionBackgroundBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPointerOver" ResourceKey="BalancedSelectionBackgroundPointerOverBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPressed" ResourceKey="BalancedSelectionBackgroundPressedBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundChecked" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPointerOver" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPressed" ResourceKey="BalancedSelectionForegroundBrush" />
                                        </ToggleButton.Resources>
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number3" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Disk Read" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.IoReadMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart
                                                x:Name="IoReadChipPlot"
                                                Grid.Column="1"
                                                MinWidth="120"
                                                Height="36"
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="Disk read metric trend chart"
                                                AutomationProperties.HelpText="Small disk read trend chart for selected process."
                                                Background="Transparent"
                                                IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton
                                        AccessKey="4"
                                        AutomationProperties.Name="Focus disk write metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsIoWriteMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="IoWrite"
                                        TabIndex="33">
                                        <ToggleButton.Resources>
                                            <StaticResource x:Key="ToggleButtonBackgroundChecked" ResourceKey="BalancedSelectionBackgroundBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPointerOver" ResourceKey="BalancedSelectionBackgroundPointerOverBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPressed" ResourceKey="BalancedSelectionBackgroundPressedBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundChecked" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPointerOver" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPressed" ResourceKey="BalancedSelectionForegroundBrush" />
                                        </ToggleButton.Resources>
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number4" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Disk Write" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.IoWriteMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart
                                                x:Name="IoWriteChipPlot"
                                                Grid.Column="1"
                                                MinWidth="120"
                                                Height="36"
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="Disk write metric trend chart"
                                                AutomationProperties.HelpText="Small disk write trend chart for selected process."
                                                Background="Transparent"
                                                IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton
                                        AccessKey="5"
                                        AutomationProperties.Name="Focus other input output metric trend"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinHeight="56"
                                        Padding="12,8"
                                        IsChecked="{x:Bind ViewModel.IsOtherIoMetricFocused, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.MetricFocusSelectedCommand}"
                                        CommandParameter="OtherIo"
                                        TabIndex="34">
                                        <ToggleButton.Resources>
                                            <StaticResource x:Key="ToggleButtonBackgroundChecked" ResourceKey="BalancedSelectionBackgroundBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPointerOver" ResourceKey="BalancedSelectionBackgroundPointerOverBrush" />
                                            <StaticResource x:Key="ToggleButtonBackgroundCheckedPressed" ResourceKey="BalancedSelectionBackgroundPressedBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundChecked" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPointerOver" ResourceKey="BalancedSelectionForegroundBrush" />
                                            <StaticResource x:Key="ToggleButtonForegroundCheckedPressed" ResourceKey="BalancedSelectionForegroundBrush" />
                                        </ToggleButton.Resources>
                                        <ToggleButton.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="Number5" Modifiers="Control,Shift" />
                                        </ToggleButton.KeyboardAccelerators>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="98" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Other I/O" />
                                                <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.OtherIoMetricChipValue, Mode=OneWay}" />
                                            </StackPanel>
                                            <controls:MetricTrendChart
                                                x:Name="OtherIoChipPlot"
                                                Grid.Column="1"
                                                MinWidth="120"
                                                Height="36"
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="Other input output metric trend chart"
                                                AutomationProperties.HelpText="Small chart for other input output transfer activity."
                                                Background="Transparent"
                                                IsTabStop="False" />
                                        </Grid>
                                    </ToggleButton>
                                </StackPanel>

                                <Border
                                    x:Name="MetricMainHost"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Padding="10"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.ExpandedMetricTitle, Mode=OneWay}" />
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                                                <TextBlock HorizontalAlignment="Right" FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.ExpandedMetricValue, Mode=OneWay}" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                                    <ToggleButton
                                                        Content="60s"
                                                        IsChecked="{x:Bind ViewModel.IsTrendWindow60Selected, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.MetricTrendWindowSelectedCommand}"
                                                        CommandParameter="60" />
                                                    <ToggleButton
                                                        Content="120s"
                                                        IsChecked="{x:Bind ViewModel.IsTrendWindow120Selected, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.MetricTrendWindowSelectedCommand}"
                                                        CommandParameter="120" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <controls:MetricTrendChart
                                            x:Name="ExpandedMetricPlot"
                                            Grid.Row="1"
                                            MinHeight="220"
                                            VerticalAlignment="Stretch"
                                            HorizontalAlignment="Stretch"
                                            AutomationProperties.Name="Expanded metric trend chart"
                                            AutomationProperties.HelpText="Detailed trend chart for the selected metric."
                                            Background="Transparent"
                                            IsTabStop="False" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="240">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="Metadata Status" />
                                    <TextBlock Text="{x:Bind ViewModel.MetadataStatus, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock FontWeight="SemiBold" Text="Parent PID" />
                                    <TextBlock Text="{x:Bind ViewModel.MetadataParentPid, Mode=OneWay}" />
                                    <TextBlock FontWeight="SemiBold" Text="Executable Path" />
                                    <TextBlock Text="{x:Bind ViewModel.MetadataExecutablePath, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock FontWeight="SemiBold" Text="Command Line" />
                                    <TextBlock Text="{x:Bind ViewModel.MetadataCommandLine, Mode=OneWay}" TextWrapping="Wrap" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid
                            x:Name="GlobalPerformanceRoot"
                            DataContext="{x:Bind ViewModel, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.GlobalPerformanceVisibility, Mode=OneWay}"
                            ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="248" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.ColumnSpan="2" Visibility="{Binding GlobalPerformanceSkeletonVisibility, Mode=OneWay}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="248" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Padding="12"
                                    Background="{StaticResource TaskMgrPaneBackgroundBrush}"
                                    BorderBrush="{StaticResource TaskMgrPaneBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel Spacing="10">
                                        <ProgressRing IsActive="True" Width="24" Height="24" />
                                        <TextBlock Style="{StaticResource TaskMgrSectionTitleStyle}" Text="Loading system metrics..." />
                                        <Rectangle Height="18" RadiusX="3" RadiusY="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="18" RadiusX="3" RadiusY="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="18" RadiusX="3" RadiusY="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Grid.Column="1"
                                    Padding="12"
                                    Background="{StaticResource TaskMgrPaneBackgroundBrush}"
                                    BorderBrush="{StaticResource TaskMgrPaneBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel Spacing="8">
                                        <Rectangle Height="22" RadiusX="4" RadiusY="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="14" RadiusX="4" RadiusY="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="230" RadiusX="4" RadiusY="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Height="80" RadiusX="4" RadiusY="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ListView
                                x:Name="GlobalResourceListView"
                                Visibility="{Binding GlobalPerformanceContentVisibility, Mode=OneWay}"
                                ItemsSource="{Binding GlobalResourceRows, Mode=OneWay}"
                                SelectionChanged="GlobalResourceListView_SelectionChanged"
                                SelectionMode="Single"
                                Background="{StaticResource TaskMgrPaneBackgroundBrush}"
                                BorderBrush="{StaticResource TaskMgrPaneBorderBrush}"
                                BorderThickness="1"
                                Padding="4">
                                <ListView.Resources>
                                    <StaticResource x:Key="ListViewItemBackgroundSelected" ResourceKey="BalancedSelectionBackgroundBrush" />
                                    <StaticResource x:Key="ListViewItemBackgroundSelectedPointerOver" ResourceKey="BalancedSelectionBackgroundPointerOverBrush" />
                                    <StaticResource x:Key="ListViewItemBackgroundSelectedPressed" ResourceKey="BalancedSelectionBackgroundPressedBrush" />
                                    <StaticResource x:Key="ListViewItemForegroundSelected" ResourceKey="BalancedSelectionForegroundBrush" />
                                    <StaticResource x:Key="ListViewItemForegroundSelectedPointerOver" ResourceKey="BalancedSelectionForegroundBrush" />
                                    <StaticResource x:Key="ListViewItemForegroundSelectedPressed" ResourceKey="BalancedSelectionForegroundBrush" />
                                    <StaticResource x:Key="ListViewItemSelectionIndicatorBrush" ResourceKey="BalancedSelectionIndicatorBrush" />
                                    <StaticResource x:Key="ListViewItemSelectionIndicatorPointerOverBrush" ResourceKey="BalancedSelectionIndicatorBrush" />
                                    <StaticResource x:Key="ListViewItemSelectionIndicatorPressedBrush" ResourceKey="BalancedSelectionIndicatorBrush" />
                                    <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">True</x:Boolean>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="MinHeight" Value="{StaticResource TaskMgrDenseRowMinHeight}" />
                                        <Setter Property="Padding" Value="{StaticResource TaskMgrResourceRowPadding}" />
                                        <Setter Property="Margin" Value="0,1" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <controls:MetricTrendChart
                                                Height="34"
                                                MinWidth="84"
                                                Values="{Binding MiniTrendValues, Mode=OneWay}"
                                                ScaleMode="{Binding MiniScaleMode, Mode=OneWay}"
                                                DomainMaxOverride="{Binding MiniDomainMax, Mode=OneWay}"
                                                ShowGrid="False"
                                                AutomationProperties.Name="Global resource mini trend chart"
                                                AutomationProperties.HelpText="Mini trend chart for a global resource."
                                                IsTabStop="False"
                                                Background="Transparent">
                                                <controls:MetricTrendChart.StrokeBrush>
                                                    <SolidColorBrush Color="{Binding MiniStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.StrokeBrush>
                                                <controls:MetricTrendChart.FillBrush>
                                                    <SolidColorBrush Color="{Binding MiniFillColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.FillBrush>
                                            </controls:MetricTrendChart>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock Style="{StaticResource TaskMgrMetricLabelStyle}" Text="{Binding Title, Mode=OneWay}" />
                                                <TextBlock Style="{StaticResource TaskMgrSectionSubtitleStyle}" Text="{Binding Subtitle, Mode=OneWay}" Visibility="{Binding SubtitleVisibility, Mode=OneWay}" />
                                                <TextBlock Style="{StaticResource TaskMgrSectionSubtitleStyle}" Text="{Binding ValueText, Mode=OneWay}" Visibility="{Binding ValueVisibility, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Border
                                Grid.Column="1"
                                Visibility="{Binding GlobalPerformanceContentVisibility, Mode=OneWay}"
                                Padding="10"
                                Background="{StaticResource TaskMgrPaneBackgroundBrush}"
                                BorderBrush="{StaticResource TaskMgrPaneBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="1">
                                            <TextBlock Style="{StaticResource TaskMgrSectionTitleStyle}" Text="{Binding GlobalDetailTitle, Mode=OneWay}" />
                                            <TextBlock Style="{StaticResource TaskMgrSectionSubtitleStyle}" Text="{Binding GlobalDetailSubtitle, Mode=OneWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="4">
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                Style="{StaticResource TaskMgrMetricValueStyle}"
                                                FontSize="22"
                                                Text="{Binding GlobalDetailCurrentValue, Mode=OneWay}" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                                <ToggleButton
                                                    Content="60s"
                                                    IsChecked="{x:Bind ViewModel.IsTrendWindow60Selected, Mode=OneWay}"
                                                    Command="{x:Bind ViewModel.MetricTrendWindowSelectedCommand}"
                                                    CommandParameter="60" />
                                                <ToggleButton
                                                    Content="120s"
                                                    IsChecked="{x:Bind ViewModel.IsTrendWindow120Selected, Mode=OneWay}"
                                                    Command="{x:Bind ViewModel.MetricTrendWindowSelectedCommand}"
                                                    CommandParameter="120" />
                                                <StackPanel Orientation="Horizontal" Spacing="6" Visibility="{Binding GlobalCpuModeToggleVisibility, Mode=OneWay}">
                                                    <ToggleButton
                                                        Content="Combined"
                                                        IsChecked="{x:Bind ViewModel.IsCpuCombinedMode, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.CpuGraphModeSelectedCommand}"
                                                        CommandParameter="Combined" />
                                                    <ToggleButton
                                                        Content="Logical"
                                                        IsChecked="{x:Bind ViewModel.IsCpuLogicalMode, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.CpuGraphModeSelectedCommand}"
                                                        CommandParameter="LogicalProcessors" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="1" RowSpacing="6">
                                        <Grid Visibility="{Binding GlobalCombinedChartVisibility, Mode=OneWay}" RowSpacing="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource TaskMgrMetricLabelStyle}" Text="{Binding GlobalPrimaryChartTitle, Mode=OneWay}" />
                                            <controls:MetricTrendChart
                                                Grid.Row="1"
                                                MinHeight="275"
                                                Values="{Binding GlobalPrimaryTrendValues, Mode=OneWay}"
                                                OverlayValues="{Binding GlobalSecondaryTrendValues, Mode=OneWay}"
                                                ShowOverlay="{Binding GlobalShowSecondaryOverlay, Mode=OneWay}"
                                                ScaleMode="{Binding GlobalPrimaryScaleMode, Mode=OneWay}"
                                                DomainMaxOverride="{Binding GlobalPrimaryDomainMax, Mode=OneWay}"
                                                ShowGrid="True"
                                                AutomationProperties.Name="Global primary trend chart"
                                                AutomationProperties.HelpText="Primary global metrics trend chart."
                                                IsTabStop="False"
                                                Background="Transparent">
                                                <controls:MetricTrendChart.StrokeBrush>
                                                    <SolidColorBrush Color="{Binding GlobalPrimaryStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.StrokeBrush>
                                                <controls:MetricTrendChart.FillBrush>
                                                    <SolidColorBrush Color="{Binding GlobalPrimaryFillColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.FillBrush>
                                                <controls:MetricTrendChart.OverlayStrokeBrush>
                                                    <SolidColorBrush Color="{Binding GlobalSecondaryStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.OverlayStrokeBrush>
                                            </controls:MetricTrendChart>
                                            <TextBlock
                                                Grid.Row="2"
                                                Style="{StaticResource TaskMgrMetricLabelStyle}"
                                                Text="{Binding GlobalAuxiliaryChartTitle, Mode=OneWay}"
                                                Visibility="{Binding GlobalAuxiliaryChartVisibility, Mode=OneWay}" />
                                            <controls:MetricTrendChart
                                                Grid.Row="3"
                                                MinHeight="100"
                                                Values="{Binding GlobalAuxiliaryTrendValues, Mode=OneWay}"
                                                ScaleMode="{Binding GlobalAuxiliaryScaleMode, Mode=OneWay}"
                                                DomainMaxOverride="{Binding GlobalAuxiliaryDomainMax, Mode=OneWay}"
                                                ShowGrid="False"
                                                ShowAreaFill="False"
                                                AutomationProperties.Name="Global auxiliary trend chart"
                                                AutomationProperties.HelpText="Auxiliary global metrics trend chart."
                                                IsTabStop="False"
                                                Background="Transparent"
                                                Visibility="{Binding GlobalAuxiliaryChartVisibility, Mode=OneWay}">
                                                <controls:MetricTrendChart.StrokeBrush>
                                                    <SolidColorBrush Color="{Binding GlobalAuxiliaryStrokeColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.StrokeBrush>
                                                <controls:MetricTrendChart.FillBrush>
                                                    <SolidColorBrush Color="{Binding GlobalAuxiliaryFillColor, Mode=OneWay}" />
                                                </controls:MetricTrendChart.FillBrush>
                                            </controls:MetricTrendChart>
                                        </Grid>

                                        <GridView
                                            x:Name="GlobalCpuLogicalGridView"
                                            Visibility="{Binding GlobalCpuLogicalGridVisibility, Mode=OneWay}"
                                            ItemsSource="{Binding GlobalCpuLogicalProcessorRows, Mode=OneWay}"
                                            IsItemClickEnabled="False"
                                            SelectionMode="None"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                            Loaded="GlobalCpuLogicalGridView_Loaded"
                                            SizeChanged="GlobalCpuLogicalGridView_SizeChanged">
                                            <GridView.ItemContainerStyle>
                                                <Style TargetType="GridViewItem">
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="2" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                </Style>
                                            </GridView.ItemContainerStyle>
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                            <GridView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid RowSpacing="2">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock
                                                            Style="{StaticResource TaskMgrMetricLabelStyle}"
                                                            Text="{Binding Title, Mode=OneWay}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <controls:MetricTrendChart
                                                            Grid.Row="1"
                                                            MinHeight="12"
                                                            Values="{Binding Values, Mode=OneWay}"
                                                            OverlayValues="{Binding OverlayValues, Mode=OneWay}"
                                                            ShowOverlay="True"
                                                            ScaleMode="CpuPercent"
                                                            StrokeBrush="{ThemeResource ChartCpuStrokeBrush}"
                                                            FillBrush="{ThemeResource ChartCpuFillBrush}"
                                                            OverlayStrokeBrush="{ThemeResource ChartCpuKernelStrokeBrush}"
                                                            AutomationProperties.Name="Logical CPU trend chart"
                                                            AutomationProperties.HelpText="Utilization trend for a logical processor."
                                                            ShowGrid="True"
                                                            IsTabStop="False"
                                                            Background="Transparent" />
                                                    </Grid>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>
                                    </Grid>

                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding GlobalDetailStats, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="260" ColumnSpacing="10" Margin="0,0,12,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource TaskMgrSectionSubtitleStyle}" Text="{Binding Label, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Right"
                                                        TextAlignment="Right"
                                                        Style="{StaticResource TaskMgrMetricValueStyle}"
                                                        Text="{Binding Value, Mode=OneWay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>

        <Border
            x:Name="FooterRegion"
            Grid.Row="2"
            Padding="{ThemeResource ShellFooterPadding}"
            BorderThickness="0,1,0,0">
            <controls:RuntimeStatusFooter DataContext="{x:Bind ViewModel, Mode=OneWay}" />
        </Border>
    </Grid>
</Window>

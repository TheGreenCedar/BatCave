                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCavePrimaryBrush}"
                            Opacity="0.46"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderBatAccentCenter"
                            Width="32"
                            Height="15"
                            Margin="0,22,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCaveTextSecondaryBrush}"
                            Opacity="0.34"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderBatAccentCenterRight"
                            Width="36"
                            Height="17"
                            Margin="164,18,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCavePrimaryBrush}"
                            Opacity="0.38"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderBatAccentUpperRight"
                            Width="62"
                            Height="30"
                            Margin="248,8,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCaveSecondaryBrush}"
                            Opacity="0.46"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderBatAccentNearRight"
                            Width="46"
                            Height="22"
                            Margin="0,24,334,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCavePrimaryBrush}"
                            Opacity="0.44"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderBatAccentRight"
                            Width="58"
                            Height="28"
                            Margin="0,8,194,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCavePrimaryBrush}"
                            Opacity="0.5"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                        <Path
                            x:Name="HeaderBatAccentFarRight"
                            Width="72"
                            Height="34"
                            Margin="0,14,56,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCaveSecondaryBrush}"
                            Opacity="0.62"
                            Data="M2,10 C6,5 10,3 15,3 C18,3 22,5 26,8 L27,10 L28,8 C32,5 36,3 39,3 C44,3 48,5 52,10 L46,9 L41,15 L34,11 L30,18 L27,14 L24,18 L19,11 L12,15 L7,9 Z" />
                    </Grid>

                    <Grid
                        x:Name="HeaderFilterInline"
                        Width="336"
                        MinWidth="296"
                        Height="48"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                        <Border
                            x:Name="HeaderFilterSurface"
                            Background="{ThemeResource BatCaveHeroInputSurfaceBrush}"
                            BorderBrush="{ThemeResource BatCaveHeroCaveStrokeBrush}"
                            BorderThickness="1.25"
                            CornerRadius="14" />
                        <TextBox
                            x:Name="FilterTextBox"
                            Margin="12,0,12,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{ThemeResource BatCaveTextPrimaryBrush}"
                            PlaceholderForeground="{ThemeResource BatCaveHeroInputPlaceholderBrush}"
                            PlaceholderText="{ThemeResource FilterPlaceholderText}"
                            Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Padding="4,0"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            AutomationProperties.HelpText="{ThemeResource ProcessFilterHelpText}"
                            AutomationProperties.Name="Process Filter" />
                    </Grid>

                    <Grid Grid.Column="1" MinWidth="0">
                        <Grid
                            x:Name="HeaderControlsInline"
                            Width="320"
                            MinWidth="280"
                            Height="96"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Path
                                x:Name="HeaderCaveShell"
                                Stretch="Fill"
                                Fill="{ThemeResource BatCaveHeroCaveShellBrush}"
                                Stroke="{ThemeResource BatCaveHeroCaveStrokeBrush}"
                                StrokeThickness="1.6"
                                Data="M18,84 Q34,46 72,24 L110,36 L160,12 L210,36 Q248,46 272,84 L240,84 Q222,62 194,54 L160,84 L126,84 L92,54 Q64,62 46,84 Z" />
                            <Path
                                x:Name="HeaderCaveCrest"
                                Margin="24,10,24,0"
                                Stretch="Fill"
                                Fill="{ThemeResource BatCavePanelAltBrush}"
                                Opacity="0.42"
                                Data="M40,36 Q66,18 98,24 L128,18 L160,24 Q192,18 218,36 L196,36 Q176,30 160,32 Q144,30 124,36 Z" />
                            <Border
                                x:Name="HeaderCaveInputSurface"
                                Margin="70,36,70,10"
                                Padding="20,10,20,10"
                                Background="{ThemeResource BatCavePanelBrush}"
                                BorderBrush="{ThemeResource BatCaveHeroCaveStrokeBrush}"
                                BorderThickness="1.5"
                                CornerRadius="20">
                                <TextBlock
                                    Style="{StaticResource BatCaveTitleTextStyle}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{ThemeResource ShellTitleText}"
                                    TextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Grid>

                    <Border
                        x:Name="HeaderAdminControlsInline"
                        Grid.Column="2"
                        Padding="12,8"
                        Background="{ThemeResource BatCaveHeroInputSurfaceBrush}"
                        BorderBrush="{ThemeResource BatCaveHeroCaveStrokeBrush}"
                        BorderThickness="1.25"
                        CornerRadius="14"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource BatCaveTextPrimaryBrush}" Text="Admin Mode" />
                            <ToggleSwitch
                                x:Name="AdminModeToggle"
                                Header=""
                                IsOn="{x:Bind ViewModel.AdminModeEnabled, Mode=OneWay}"
                                OffContent=""
                                OnContent=""
                                Toggled="AdminModeToggle_Toggled"
                                AutomationProperties.HelpText="{ThemeResource AdminToggleHelpText}"
                                AutomationProperties.Name="Admin Mode Toggle" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="HeaderControlsPhone" Grid.Row="2" Visibility="Collapsed" Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid
                        x:Name="HeaderBrandPhone"
                        Width="232"
                        Height="76"
                        HorizontalAlignment="Center">
                        <Path
                            x:Name="HeaderBatAccentPhoneFarLeft"
                            Width="34"
                            Height="16"
                            Margin="16,12,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Fill="{ThemeResource BatCaveSecondaryBrush}"
                            Opacity="0.56"
                            IsHitTestVisible="False"

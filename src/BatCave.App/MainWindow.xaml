<Window
    x:Class="BatCave.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BatCave.App.Controls"
    xmlns:presentation="using:BatCave.App.Presentation"
    Title="BatCave">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="Root"
        Background="{ThemeResource BatCavePageBackgroundBrush}"
        Loaded="Root_Loaded"
        SizeChanged="Root_SizeChanged">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FocusFilter_Invoked" />
            <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="Refresh_Invoked" />
            <KeyboardAccelerator Key="Space" Modifiers="Control" Invoked="TogglePause_Invoked" />
            <KeyboardAccelerator Key="Escape" Invoked="ClearSelection_Invoked" />
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="0"
            Padding="16,12"
            Background="{ThemeResource BatCaveSurfaceBrush}"
            ColumnSpacing="12"
            RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource BatCaveTextPrimaryBrush}"
                    Text="BatCave" />
                <TextBlock
                    Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                    Text="{x:Bind ViewModel.ProcessCountText, Mode=OneWay}" />
            </StackPanel>

            <TextBox
                x:Name="FilterBox"
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                VerticalAlignment="Center"
                PlaceholderText="Filter by process name or PID"
                Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                AutomationProperties.Name="Process Filter"
                AutomationProperties.HelpText="Type a process name or process id to filter the process list." />

            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <ToggleSwitch
                    x:Name="AdminToggle"
                    Header="Admin Mode"
                    IsOn="{x:Bind ViewModel.AdminModeRequested, Mode=OneWay}"
                    Toggled="AdminToggle_Toggled"
                    AutomationProperties.Name="Admin Mode" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                    Text="{x:Bind ViewModel.AdminStatusText, Mode=OneWay}" />
                <Button
                    Command="{x:Bind ViewModel.RetryAdminModeCommand}"
                    Visibility="{x:Bind ViewModel.RetryAdminModeVisibility, Mode=OneWay}"
                    AutomationProperties.Name="Retry Admin Mode"
                    ToolTipService.ToolTip="Retry admin mode">
                    <SymbolIcon Symbol="Setting" />
                </Button>

                <CommandBar
                    DefaultLabelPosition="Collapsed"
                    Background="Transparent"
                    Foreground="{ThemeResource BatCaveTextPrimaryBrush}">
                    <AppBarButton
                        Icon="Refresh"
                        Label="Refresh"
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.Name="Refresh Now" />
                    <AppBarButton
                        Icon="Pause"
                        Label="Pause"
                        Command="{x:Bind ViewModel.PauseCommand}"
                        AutomationProperties.Name="Pause Runtime" />
                    <AppBarButton
                        Icon="Play"
                        Label="Resume"
                        Command="{x:Bind ViewModel.ResumeCommand}"
                        AutomationProperties.Name="Resume Runtime" />
                </CommandBar>
            </StackPanel>
        </Grid>

        <Grid
            x:Name="WorkspaceGrid"
            Grid.Row="1"
            Padding="16,8,16,16"
            ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ProcessColumn" Width="*" />
                <ColumnDefinition x:Name="InspectorColumn" Width="420" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ProcessWorkspaceRow" Height="*" />
                <RowDefinition x:Name="InspectorWorkspaceRow" Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                x:Name="ProcessPane"
                Grid.Row="0"
                Grid.Column="0"
                MinWidth="0"
                VerticalAlignment="Top"
                Background="{ThemeResource BatCaveSurfaceBrush}"
                BorderBrush="{ThemeResource BatCaveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource BatCaveControlCornerRadius}">
                <Grid>
                <Grid
                    x:Name="DesktopProcessTable"
                    RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid
                        Grid.Row="0"
                        Padding="12,10"
                        ColumnSpacing="8"
                        Background="{ThemeResource BatCaveSurfaceAltBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="NameSortButton" Grid.Column="0" Tag="Name" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinWidth="0" Padding="8,4" Content="Name" AutomationProperties.Name="Sort by Name" />
                        <Button x:Name="CpuSortButton" Grid.Column="1" Tag="CpuPct" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="CPU" AutomationProperties.Name="Sort by CPU" />
                        <Button x:Name="MemorySortButton" Grid.Column="2" Tag="MemoryBytes" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="Memory" AutomationProperties.Name="Sort by Memory" />
                        <Button x:Name="DiskSortButton" Grid.Column="3" Tag="DiskBps" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="Disk" AutomationProperties.Name="Sort by Disk" />
                        <Button x:Name="OtherIoSortButton" Grid.Column="4" Tag="OtherIoBps" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="Other I/O" AutomationProperties.Name="Sort by Other I/O" />
                        <Button x:Name="PidSortButton" Grid.Column="5" Tag="Pid" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="PID" AutomationProperties.Name="Sort by PID" />
                    </Grid>

                    <ListView
                        x:Name="ProcessList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedRow, Mode=TwoWay}"
                        SelectionMode="Single"
                        IsItemClickEnabled="False"
                        SelectionChanged="ProcessList_SelectionChanged"
                        AutomationProperties.Name="Process List">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="44" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="presentation:ProcessRowViewModel">
                                <Grid Padding="12,8" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" FontSize="12" Text="{x:Bind PidText}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind CpuText}" />
                                    <TextBlock Grid.Column="2" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind MemoryText}" />
                                    <TextBlock Grid.Column="3" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind DiskText}" />
                                    <TextBlock Grid.Column="4" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind OtherIoText}" />
                                    <TextBlock Grid.Column="5" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind PidText}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
                <Grid
                    x:Name="CompactProcessSurface"
                    RowSpacing="0"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid
                        Grid.Row="0"
                        Padding="10,8"
                        ColumnSpacing="8"
                        Background="{ThemeResource BatCaveSurfaceAltBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                            Text="{x:Bind ViewModel.ProcessSortText, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Content="Sort"
                            AutomationProperties.Name="Compact Sort">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Name" Tag="Name" Click="SortMenuItem_Click" />
                                    <MenuFlyoutItem Text="CPU" Tag="CpuPct" Click="SortMenuItem_Click" />
                                    <MenuFlyoutItem Text="Memory" Tag="MemoryBytes" Click="SortMenuItem_Click" />
                                    <MenuFlyoutItem Text="Disk" Tag="DiskBps" Click="SortMenuItem_Click" />
                                    <MenuFlyoutItem Text="Other I/O" Tag="OtherIoBps" Click="SortMenuItem_Click" />
                                    <MenuFlyoutItem Text="PID" Tag="Pid" Click="SortMenuItem_Click" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    <ListView
                        x:Name="CompactProcessList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedRow, Mode=TwoWay}"
                        SelectionMode="Single"
                        IsItemClickEnabled="False"
                        SelectionChanged="ProcessList_SelectionChanged"
                        Visibility="Collapsed"
                        AutomationProperties.Name="Compact Process List">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="50" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="presentation:ProcessRowViewModel">
                                <Grid Padding="10,4" RowSpacing="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" MinWidth="0" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" FontSize="12" Text="{x:Bind PidCompactText}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind CpuCompactText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind MemoryCompactText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind DiskCompactText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind OtherIoCompactText}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
                </Grid>
            </Border>

            <Border
                x:Name="InspectorPane"
                Grid.Row="0"
                Grid.Column="1"
                MinWidth="0"
                VerticalAlignment="Top"
                Background="{ThemeResource BatCaveSurfaceBrush}"
                BorderBrush="{ThemeResource BatCaveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource BatCaveControlCornerRadius}"
                AutomationProperties.Name="Inspector">
                <ScrollViewer
                    Padding="10"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="INSPECTOR" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.InspectorTitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <Button
                                Grid.Column="1"
                                Command="{x:Bind ViewModel.ClearSelectionCommand}"
                                Visibility="{x:Bind ViewModel.ClearSelectionVisibility, Mode=OneWay}"
                                AutomationProperties.Name="Show System Overview"
                                ToolTipService.ToolTip="Show system overview">
                                <SymbolIcon Symbol="Home" />
                            </Button>
                        </Grid>
                        <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.InspectorSubtitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <InfoBar
                        IsOpen="{x:Bind ViewModel.HasWarning, Mode=OneWay}"
                        Severity="Warning"
                        Title="Runtime Notice"
                        Message="{x:Bind ViewModel.WarningText, Mode=OneWay}" />

                    <Grid
                        x:Name="InspectorMetricsGrid"
                        ColumnSpacing="10"
                        RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="InspectorMetricsSecondColumn" Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border x:Name="CpuMetricCard" Grid.Row="0" Grid.Column="0" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="CPU" />
                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorCpuText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="MemoryMetricCard" Grid.Row="0" Grid.Column="1" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="MEMORY" />
                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorMemoryText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="DiskMetricCard" Grid.Row="1" Grid.Column="0" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="DISK" />
                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorDiskText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="OtherIoMetricCard" Grid.Row="1" Grid.Column="1" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="OTHER I/O" />
                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorOtherIoText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="ThreadsMetricCard" Grid.Row="2" Grid.ColumnSpan="2" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="THREADS / LOGICAL PROCESSORS" />
                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorThreadText, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="CPU TREND" />
                        <controls:SparklineControl Values="{x:Bind ViewModel.CpuTrendValues, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="MEMORY TREND" />
                        <controls:SparklineControl Values="{x:Bind ViewModel.MemoryTrendValues, Mode=OneWay}" />
                    </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid
            Grid.Row="2"
            Padding="16,8"
            Background="{ThemeResource BatCaveSurfaceBrush}"
            ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CpuText, Mode=OneWay}" />
            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.TickText, Mode=OneWay}" />
            <TextBlock Grid.Column="3" Text="{x:Bind ViewModel.SortText, Mode=OneWay}" />
        </Grid>
    </Grid>
</Window>

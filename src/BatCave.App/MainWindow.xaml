<Window
    x:Class="BatCave.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BatCave.App.Controls"
    xmlns:presentation="using:BatCave.App.Presentation"
    Title="BatCave">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="Root"
        Background="{ThemeResource BatCavePageBackgroundBrush}"
        Loaded="Root_Loaded"
        SizeChanged="Root_SizeChanged">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FocusFilter_Invoked" />
            <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="Refresh_Invoked" />
            <KeyboardAccelerator Key="Space" Modifiers="Control" Invoked="TogglePause_Invoked" />
            <KeyboardAccelerator Key="Escape" Invoked="ClearSelection_Invoked" />
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="0"
            Padding="16,12"
            Background="{ThemeResource BatCaveSurfaceBrush}"
            ColumnSpacing="12"
            RowSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource BatCaveTextPrimaryBrush}"
                    Text="BatCave" />
                <TextBlock
                    Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                    Text="{x:Bind ViewModel.ProcessCountText, Mode=OneWay}" />
            </StackPanel>

            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                VerticalAlignment="Center"
                Spacing="2">
                <TextBlock
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource BatCaveTextPrimaryBrush}"
                    Text="{x:Bind ViewModel.RuntimeConfidenceText, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                    Text="{x:Bind ViewModel.RuntimePerfText, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <ToggleSwitch
                    x:Name="AdminToggle"
                    Header="Admin Mode"
                    IsOn="{x:Bind ViewModel.AdminModeRequested, Mode=OneWay}"
                    Toggled="AdminToggle_Toggled"
                    AutomationProperties.Name="Admin Mode"
                    ToolTipService.ToolTip="{x:Bind ViewModel.AdminStatusText, Mode=OneWay}" />
                <Button
                    Command="{x:Bind ViewModel.RetryAdminModeCommand}"
                    Visibility="{x:Bind ViewModel.RetryAdminModeVisibility, Mode=OneWay}"
                    AutomationProperties.Name="Retry Admin Mode"
                    ToolTipService.ToolTip="Retry admin mode">
                    <SymbolIcon Symbol="Setting" />
                </Button>

                <CommandBar
                    DefaultLabelPosition="Collapsed"
                    Background="Transparent"
                    Foreground="{ThemeResource BatCaveTextPrimaryBrush}">
                    <AppBarButton
                        Icon="Refresh"
                        Label="Refresh"
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        AutomationProperties.Name="Refresh Now"
                        ToolTipService.ToolTip="Refresh now" />
                    <AppBarButton
                        Icon="Pause"
                        Label="Pause"
                        Command="{x:Bind ViewModel.PauseCommand}"
                        AutomationProperties.Name="Pause Runtime"
                        ToolTipService.ToolTip="Pause runtime" />
                    <AppBarButton
                        Icon="Play"
                        Label="Resume"
                        Command="{x:Bind ViewModel.ResumeCommand}"
                        AutomationProperties.Name="Resume Runtime"
                        ToolTipService.ToolTip="Resume runtime" />
                </CommandBar>
            </StackPanel>

            <Grid
                Grid.Row="1"
                Grid.ColumnSpan="3"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="FilterBox"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    PlaceholderText="Filter by process name or PID"
                    Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AutomationProperties.Name="Process Filter"
                    AutomationProperties.HelpText="Type a process name or process id to filter the process list." />
                <Button
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.ClearFilterCommand}"
                    Visibility="{x:Bind ViewModel.ClearFilterVisibility, Mode=OneWay}"
                    AutomationProperties.Name="Clear Process Filter"
                    ToolTipService.ToolTip="Clear filter">
                    <SymbolIcon Symbol="Clear" />
                </Button>
                <TextBlock
                    Grid.Column="2"
                    MinWidth="84"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                    Text="{x:Bind ViewModel.FilterMatchText, Mode=OneWay}" />
            </Grid>

            <ScrollViewer
                Grid.Row="2"
                Grid.ColumnSpan="3"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                        Text="{x:Bind ViewModel.ActiveQuickFilterText, Mode=OneWay}" />
                    <Button Content="All" Command="{x:Bind ViewModel.ApplyQuickFilterCommand}" CommandParameter="All" AutomationProperties.Name="Show All Processes" />
                    <Button Content="High CPU" Command="{x:Bind ViewModel.ApplyQuickFilterCommand}" CommandParameter="HighCpu" AutomationProperties.Name="Filter High CPU Processes" />
                    <Button Content="High Memory" Command="{x:Bind ViewModel.ApplyQuickFilterCommand}" CommandParameter="HighMemory" AutomationProperties.Name="Filter High Memory Processes" />
                    <Button Content="Active I/O" Command="{x:Bind ViewModel.ApplyQuickFilterCommand}" CommandParameter="ActiveIo" AutomationProperties.Name="Filter Active I/O Processes" />
                    <Button Content="Limited Access" Command="{x:Bind ViewModel.ApplyQuickFilterCommand}" CommandParameter="LimitedAccess" AutomationProperties.Name="Filter Limited Access Processes" />
                </StackPanel>
            </ScrollViewer>

            <NavigationView
                x:Name="WorkflowNav"
                Grid.Row="3"
                Grid.ColumnSpan="3"
                PaneDisplayMode="Top"
                IsSettingsVisible="False"
                IsBackButtonVisible="Collapsed"
                SelectionChanged="WorkflowNav_SelectionChanged"
                AutomationProperties.Name="Workflow Navigation">
                <NavigationView.MenuItems>
                    <NavigationViewItem x:Name="OverviewNavItem" Content="Overview" Icon="View" Tag="Overview" />
                    <NavigationViewItem Content="Processes" Icon="List" Tag="Processes" />
                    <NavigationViewItem Content="Health" Icon="Repair" Tag="Health" />
                    <NavigationViewItem Content="Validation" Icon="Accept" Tag="Validation" />
                </NavigationView.MenuItems>
            </NavigationView>
        </Grid>

        <Grid
            x:Name="WorkspaceGrid"
            Grid.Row="1"
            Padding="16,8,16,16"
            ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ProcessColumn" Width="*" />
                <ColumnDefinition x:Name="InspectorColumn" Width="420" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ProcessWorkspaceRow" Height="*" />
                <RowDefinition x:Name="InspectorWorkspaceRow" Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                x:Name="ProcessPane"
                Grid.Row="0"
                Grid.Column="0"
                MinWidth="0"
                VerticalAlignment="Top"
                Background="{ThemeResource BatCaveSurfaceBrush}"
                BorderBrush="{ThemeResource BatCaveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource BatCaveControlCornerRadius}"
                Visibility="{x:Bind ViewModel.ProcessWorkspaceVisibility, Mode=OneWay}">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        x:Name="TriageCockpit"
                        Grid.Row="0"
                        Padding="12"
                        Background="{ThemeResource BatCaveSurfaceAltBrush}"
                        BorderBrush="{ThemeResource BatCaveBorderBrush}"
                        BorderThickness="0,0,0,1"
                        AutomationProperties.Name="Attention Cockpit">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="{x:Bind ViewModel.TriageHeadlineText, Mode=OneWay}" />
                                    <TextBlock
                                        Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                                        Text="{x:Bind ViewModel.TriageSummaryText, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Command="{x:Bind ViewModel.SortCommand}"
                                    CommandParameter="Attention"
                                    AutomationProperties.Name="Sort by Attention from Cockpit"
                                    ToolTipService.ToolTip="Sort by attention">
                                    <SymbolIcon Symbol="Filter" />
                                </Button>
                            </Grid>

                            <ScrollViewer
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Disabled">
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Border MinWidth="190" MaxWidth="260" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="ATTENTION" />
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.TriageAttentionTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.TriageAttentionDetail, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                    <Border MinWidth="190" MaxWidth="260" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="CPU LEADER" />
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.TriageCpuTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.TriageCpuDetail, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <Button Content="Show" Command="{x:Bind ViewModel.ApplyQuickFilterCommand}" CommandParameter="HighCpu" HorizontalAlignment="Left" AutomationProperties.Name="Show High CPU Processes" />
                                        </StackPanel>
                                    </Border>
                                    <Border MinWidth="190" MaxWidth="260" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="MEMORY LEADER" />
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.TriageMemoryTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.TriageMemoryDetail, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <Button Content="Show" Command="{x:Bind ViewModel.ApplyQuickFilterCommand}" CommandParameter="HighMemory" HorizontalAlignment="Left" AutomationProperties.Name="Show High Memory Processes" />
                                        </StackPanel>
                                    </Border>
                                    <Border MinWidth="190" MaxWidth="260" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="I/O OR ACCESS" />
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.TriageIoAccessTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.TriageIoAccessDetail, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <Button Content="Show I/O" Command="{x:Bind ViewModel.ApplyQuickFilterCommand}" CommandParameter="ActiveIo" HorizontalAlignment="Left" AutomationProperties.Name="Show Active I/O Processes" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <Grid
                                x:Name="OverviewChartGrid"
                                ColumnSpacing="10"
                                RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Column="0" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="CPU SIMPLE CHART" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SystemCpuChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.SystemCpuTrendValues, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="CPU MULTI-CORE VIEW" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.LogicalCpuChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{x:Bind ViewModel.LogicalCpuCharts, Mode=OneWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <ItemsStackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="presentation:LogicalCpuChartViewModel">
                                                        <StackPanel Width="104" Margin="0,0,8,0" Spacing="4">
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Title, Mode=OneWay}" />
                                                            <controls:SparklineControl Values="{x:Bind Values, Mode=OneWay}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="LIVE MEMORY CHART" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SystemMemoryChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.SystemMemoryTrendValues, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="DISK READ CHART" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SystemDiskReadChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.SystemDiskReadTrendValues, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="0" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="DISK WRITE CHART" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SystemDiskWriteChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.SystemDiskWriteTrendValues, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="1" Background="{ThemeResource BatCaveSurfaceBrush}" BorderBrush="{ThemeResource BatCaveBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="LIVE NETWORK CHART" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SystemNetworkChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.SystemNetworkTrendValues, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid
                        x:Name="DesktopProcessTable"
                        Grid.Row="1"
                        RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid
                            Grid.Row="0"
                            Padding="12,10"
                            ColumnSpacing="8"
                            Background="{ThemeResource BatCaveSurfaceAltBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="74" />
                                <ColumnDefinition Width="108" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="74" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="NameSortButton" Grid.Column="0" Tag="Name" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinWidth="0" Padding="8,4" Content="Name" AutomationProperties.Name="Sort by Name" />
                            <Button x:Name="AttentionSortButton" Grid.Column="1" Tag="Attention" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinWidth="0" Padding="8,4" Content="Attention" AutomationProperties.Name="Sort by Attention" />
                            <Button x:Name="CpuSortButton" Grid.Column="2" Tag="CpuPct" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="CPU" AutomationProperties.Name="Sort by CPU" />
                            <Button x:Name="MemorySortButton" Grid.Column="3" Tag="MemoryBytes" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="Memory" AutomationProperties.Name="Sort by Memory" />
                            <Button x:Name="DiskSortButton" Grid.Column="4" Tag="DiskBps" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="Disk" AutomationProperties.Name="Sort by Disk" />
                            <Button x:Name="OtherIoSortButton" Grid.Column="5" Tag="OtherIoBps" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="Other I/O" AutomationProperties.Name="Sort by Other I/O" />
                            <Button x:Name="PidSortButton" Grid.Column="6" Tag="Pid" Click="SortButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" MinWidth="0" Padding="8,4" Content="PID" AutomationProperties.Name="Sort by PID" />
                        </Grid>

                        <ListView
                            x:Name="ProcessList"
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedRow, Mode=TwoWay}"
                            SelectionMode="Single"
                            IsItemClickEnabled="False"
                            SelectionChanged="ProcessList_SelectionChanged"
                            AutomationProperties.Name="Process List">
                            <ListView.Resources>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="{ThemeResource BatCaveRowHoverColor}" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="{ThemeResource BatCaveSelectionColor}" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{ThemeResource BatCaveSelectionColor}" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="{ThemeResource BatCaveSelectionColor}" />
                                <SolidColorBrush x:Key="ListViewItemForegroundPointerOver" Color="{ThemeResource BatCaveTextPrimaryColor}" />
                                <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="{ThemeResource BatCaveTextPrimaryColor}" />
                                <SolidColorBrush x:Key="ListViewItemForegroundSelectedPointerOver" Color="{ThemeResource BatCaveTextPrimaryColor}" />
                            </ListView.Resources>
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection />
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="44" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="presentation:ProcessRowViewModel">
                                    <Grid Padding="12,8" ColumnSpacing="8" RightTapped="ProcessRow_RightTapped">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Copy details" Tag="CopyDetails" Click="ProcessRowMenuItem_Click" />
                                                <MenuFlyoutItem Text="Copy PID" Tag="CopyPid" Click="ProcessRowMenuItem_Click" />
                                                <MenuFlyoutItem Text="Filter to process" Tag="FilterToProcess" Click="ProcessRowMenuItem_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Show system overview" Tag="ClearSelection" Click="ProcessRowMenuItem_Click" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="74" />
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="104" />
                                            <ColumnDefinition Width="74" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" FontSize="12" Text="{x:Bind PidCompactText, Mode=OneWay}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind AttentionBadgeText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind CpuText, Mode=OneWay}" />
                                        <TextBlock Grid.Column="3" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind MemoryText, Mode=OneWay}" />
                                        <TextBlock Grid.Column="4" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind DiskText, Mode=OneWay}" />
                                        <TextBlock Grid.Column="5" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind OtherIoText, Mode=OneWay}" />
                                        <TextBlock Grid.Column="6" FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right" Text="{x:Bind PidText, Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <Grid
                        x:Name="CompactProcessSurface"
                        Grid.Row="1"
                        RowSpacing="0"
                        Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid
                            Grid.Row="0"
                            Padding="10,8"
                            ColumnSpacing="8"
                            Background="{ThemeResource BatCaveSurfaceAltBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                                Text="{x:Bind ViewModel.ProcessSortText, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <Button
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Content="Sort"
                                AutomationProperties.Name="Compact Sort">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Attention" Tag="Attention" Click="SortMenuItem_Click" />
                                        <MenuFlyoutItem Text="Name" Tag="Name" Click="SortMenuItem_Click" />
                                        <MenuFlyoutItem Text="CPU" Tag="CpuPct" Click="SortMenuItem_Click" />
                                        <MenuFlyoutItem Text="Memory" Tag="MemoryBytes" Click="SortMenuItem_Click" />
                                        <MenuFlyoutItem Text="Disk" Tag="DiskBps" Click="SortMenuItem_Click" />
                                        <MenuFlyoutItem Text="Other I/O" Tag="OtherIoBps" Click="SortMenuItem_Click" />
                                        <MenuFlyoutItem Text="PID" Tag="Pid" Click="SortMenuItem_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <ListView
                            x:Name="CompactProcessList"
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedRow, Mode=TwoWay}"
                            SelectionMode="Single"
                            IsItemClickEnabled="False"
                            SelectionChanged="ProcessList_SelectionChanged"
                            Visibility="Collapsed"
                            AutomationProperties.Name="Compact Process List">
                            <ListView.Resources>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="{ThemeResource BatCaveRowHoverColor}" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="{ThemeResource BatCaveSelectionColor}" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{ThemeResource BatCaveSelectionColor}" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="{ThemeResource BatCaveSelectionColor}" />
                                <SolidColorBrush x:Key="ListViewItemForegroundPointerOver" Color="{ThemeResource BatCaveTextPrimaryColor}" />
                                <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="{ThemeResource BatCaveTextPrimaryColor}" />
                                <SolidColorBrush x:Key="ListViewItemForegroundSelectedPointerOver" Color="{ThemeResource BatCaveTextPrimaryColor}" />
                            </ListView.Resources>
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection />
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="56" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="presentation:ProcessRowViewModel">
                                    <Grid Padding="10,5" RowSpacing="2" RightTapped="ProcessRow_RightTapped">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Copy details" Tag="CopyDetails" Click="ProcessRowMenuItem_Click" />
                                                <MenuFlyoutItem Text="Copy PID" Tag="CopyPid" Click="ProcessRowMenuItem_Click" />
                                                <MenuFlyoutItem Text="Filter to process" Tag="FilterToProcess" Click="ProcessRowMenuItem_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Show system overview" Tag="ClearSelection" Click="ProcessRowMenuItem_Click" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" MinWidth="0" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" FontSize="12" Text="{x:Bind AttentionBadgeText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                        <Grid Grid.Row="1" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind CpuCompactText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind MemoryCompactText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind DiskCompactText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" MinWidth="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind OtherIoCompactText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Padding="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource BatCaveSurfaceAltBrush}"
                        CornerRadius="{ThemeResource BatCaveControlCornerRadius}"
                        Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                        IsHitTestVisible="False">
                        <TextBlock
                            Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                            Text="{x:Bind ViewModel.EmptyStateText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </Grid>
            </Border>

            <Border
                x:Name="InspectorPane"
                Grid.Row="0"
                Grid.Column="1"
                MinWidth="0"
                VerticalAlignment="Top"
                Background="{ThemeResource BatCaveSurfaceBrush}"
                BorderBrush="{ThemeResource BatCaveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource BatCaveControlCornerRadius}"
                Visibility="{x:Bind ViewModel.InspectorWorkspaceVisibility, Mode=OneWay}"
                AutomationProperties.Name="Inspector">
                <ScrollViewer
                    Padding="10"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="INSPECTOR" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.InspectorTitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                <Button
                                    Grid.Column="1"
                                    Click="CopyDetails_Click"
                                    Visibility="{x:Bind ViewModel.CopyDetailsVisibility, Mode=OneWay}"
                                    Background="{ThemeResource BatCaveSurfaceAltBrush}"
                                    BorderBrush="{ThemeResource BatCaveBorderBrush}"
                                    Foreground="{ThemeResource BatCaveTextPrimaryBrush}"
                                    AutomationProperties.Name="Copy Process Details"
                                    ToolTipService.ToolTip="Copy process details">
                                    <SymbolIcon Symbol="Copy" />
                                </Button>
                                <Button
                                    Grid.Column="2"
                                    Command="{x:Bind ViewModel.ClearSelectionCommand}"
                                    Visibility="{x:Bind ViewModel.ClearSelectionVisibility, Mode=OneWay}"
                                    Background="{ThemeResource BatCaveSurfaceAltBrush}"
                                    BorderBrush="{ThemeResource BatCaveBorderBrush}"
                                    Foreground="{ThemeResource BatCaveTextPrimaryBrush}"
                                    AutomationProperties.Name="Show System Overview"
                                    ToolTipService.ToolTip="Show system overview">
                                    <SymbolIcon Symbol="Home" />
                                </Button>
                            </Grid>
                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.InspectorSubtitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <InfoBar
                            IsOpen="{x:Bind ViewModel.HasWarning, Mode=OneWay}"
                            Severity="Warning"
                            Title="Runtime Notice"
                            Message="{x:Bind ViewModel.WarningText, Mode=OneWay}" />

                        <Pivot AutomationProperties.Name="Inspector Mode Tabs">
                            <PivotItem Header="Summary">
                                <StackPanel Spacing="10">
                                    <Grid
                                        x:Name="InspectorMetricsGrid"
                                        ColumnSpacing="10"
                                        RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition x:Name="InspectorMetricsSecondColumn" Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border x:Name="CpuMetricCard" Grid.Row="0" Grid.Column="0" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="CPU" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorCpuText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="MemoryMetricCard" Grid.Row="0" Grid.Column="1" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="MEMORY" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorMemoryText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="DiskMetricCard" Grid.Row="1" Grid.Column="0" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="DISK" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorDiskText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="OtherIoMetricCard" Grid.Row="1" Grid.Column="1" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="OTHER I/O" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorOtherIoText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="ThreadsMetricCard" Grid.Row="2" Grid.ColumnSpan="2" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="THREADS / LOGICAL PROCESSORS" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{x:Bind ViewModel.InspectorThreadText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="ATTENTION" />
                                    <TextBlock Text="{x:Bind ViewModel.InspectorAttentionText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.InspectorLastChangeText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="STORY" />
                                    <TextBlock Text="{x:Bind ViewModel.ProcessStoryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.ProcessTimelineItems, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Margin="0,3,0,0"
                                                    Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                                                    Text="{Binding}"
                                                    TextWrapping="WrapWholeWords" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </PivotItem>

                            <PivotItem Header="Performance">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="RUNTIME CONFIDENCE" />
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.RuntimeConfidenceText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.RuntimePerfText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.RuntimeBudgetText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <Border Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="NEXT ACTION" />
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.RuntimeActionTitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.RuntimeActionDetail, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.TrendScopeText, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="{x:Bind ViewModel.CpuTrendLabelText, Mode=OneWay}" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.CpuTrendValues, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="{x:Bind ViewModel.MemoryTrendLabelText, Mode=OneWay}" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.MemoryTrendValues, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="DISK TREND" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.DiskTrendValues, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="NETWORK / OTHER I/O TREND" />
                                        <controls:SparklineControl Values="{x:Bind ViewModel.OtherIoTrendValues, Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>
                            </PivotItem>

                            <PivotItem Header="Details">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="PROCESS DETAILS" />
                                    <Grid ColumnSpacing="10" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Parent PID" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.InspectorParentPidText, Mode=OneWay}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Started" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.InspectorStartTimeText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Access" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.InspectorAccessStateText, Mode=OneWay}" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Private memory" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.InspectorPrivateMemoryText, Mode=OneWay}" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Handles" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.InspectorHandlesText, Mode=OneWay}" />
                                    </Grid>

                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="VALIDATION" />
                                    <Border Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="10">
                                        <StackPanel Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.BenchmarkStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.BenchmarkBudgetText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.BenchmarkEvidenceText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12" Text="{x:Bind ViewModel.BenchmarkCommandText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12" Text="{x:Bind ViewModel.ValidationCommandText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </PivotItem>
                        </Pivot>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border
                x:Name="HealthPane"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="{ThemeResource BatCaveSurfaceBrush}"
                BorderBrush="{ThemeResource BatCaveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource BatCaveControlCornerRadius}"
                Visibility="{x:Bind ViewModel.HealthWorkspaceVisibility, Mode=OneWay}"
                AutomationProperties.Name="Health Workspace">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="HEALTH" />
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.HealthHeadlineText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.HealthSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="RUNTIME DIAGNOSTICS" />
                                    <TextBlock Text="{x:Bind ViewModel.HealthDiagnosticsText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="ACCESS" />
                                    <TextBlock Text="{x:Bind ViewModel.AccessSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="LOCAL DATA" />
                                    <TextBlock Text="{x:Bind ViewModel.LocalDataSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12" Text="%LOCALAPPDATA%\BatCaveMonitor" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="RUNTIME CHARTS" />
                                    <Grid ColumnSpacing="10" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.TickP95ChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <controls:SparklineControl Values="{x:Bind ViewModel.TickP95TrendValues, Mode=OneWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SortP95ChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <controls:SparklineControl Values="{x:Bind ViewModel.SortP95TrendValues, Mode=OneWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.JitterP95ChartText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                            <controls:SparklineControl Values="{x:Bind ViewModel.JitterP95TrendValues, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border
                x:Name="ValidationPane"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="{ThemeResource BatCaveSurfaceBrush}"
                BorderBrush="{ThemeResource BatCaveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource BatCaveControlCornerRadius}"
                Visibility="{x:Bind ViewModel.ValidationWorkspaceVisibility, Mode=OneWay}"
                AutomationProperties.Name="Validation Workspace">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="VALIDATION" />
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.ValidationHeadlineText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <TextBlock Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.ValidationSummaryText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="BENCHMARK" />
                                    <TextBlock Text="{x:Bind ViewModel.BenchmarkEvidenceText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12" Text="{x:Bind ViewModel.BenchmarkCommandText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{ThemeResource BatCaveSurfaceAltBrush}" CornerRadius="6" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="HANDOFF GATE" />
                                    <TextBlock Text="Build, tests, runtime diagnostics, and launch smoke run through the repository gate." TextWrapping="WrapWholeWords" />
                                    <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="12" Text="{x:Bind ViewModel.ValidationCommandText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid
            Grid.Row="2"
            Padding="16,8"
            Background="{ThemeResource BatCaveSurfaceBrush}"
            ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.FooterCpuText, Mode=OneWay}" />
            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.FooterTickText, Mode=OneWay}" />
            <TextBlock Grid.Column="3" Text="{x:Bind ViewModel.FooterSortP95Text, Mode=OneWay}" />
            <TextBlock Grid.Column="4" Foreground="{ThemeResource BatCaveTextSecondaryBrush}" Text="{x:Bind ViewModel.WorkflowStatusText, Mode=OneWay}" />
        </Grid>
    </Grid>
</Window>

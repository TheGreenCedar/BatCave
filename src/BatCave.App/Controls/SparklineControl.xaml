<UserControl
    x:Class="BatCave.App.Controls.SparklineControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="76"
    MinHeight="76"
    UseLayoutRounding="True">
    <Border
        Padding="8"
        Background="{ThemeResource BatCaveSurfaceAltBrush}"
        BorderBrush="{ThemeResource BatCaveBorderBrush}"
        BorderThickness="1"
        CornerRadius="{ThemeResource BatCaveControlCornerRadius}">
        <Grid>
            <Rectangle
                Height="1"
                VerticalAlignment="Top"
                Fill="{ThemeResource BatCaveChartGridBrush}" />
            <Rectangle
                Height="1"
                VerticalAlignment="Center"
                Fill="{ThemeResource BatCaveChartGridBrush}" />
            <Rectangle
                Height="1"
                VerticalAlignment="Bottom"
                Fill="{ThemeResource BatCaveChartGridBrush}" />
            <Canvas x:Name="PlotCanvas">
                <Polygon
                    x:Name="Area"
                    Fill="{ThemeResource BatCaveChartFillBrush}" />
                <Polyline
                    x:Name="Line"
                    Stroke="{ThemeResource BatCavePrimaryBrush}"
                    StrokeThickness="2"
                    StrokeLineJoin="Round" />
            </Canvas>
            <TextBlock
                x:Name="EmptyState"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource BatCaveTextSecondaryBrush}"
                Text="Collecting"
                Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>

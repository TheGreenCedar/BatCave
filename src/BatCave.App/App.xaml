<Application
    x:Class="BatCave.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="BatCavePageBackgroundColor">#FFF4F6F8</Color>
                    <Color x:Key="BatCaveSurfaceColor">#FFFFFFFF</Color>
                    <Color x:Key="BatCaveSurfaceAltColor">#FFE8EDF3</Color>
                    <Color x:Key="BatCaveBorderColor">#FFD5DDE7</Color>
                    <Color x:Key="BatCavePrimaryColor">#FF2563EB</Color>
                    <Color x:Key="BatCaveSelectionColor">#FFEAF2FF</Color>
                    <Color x:Key="BatCaveRowHoverColor">#FFF6F8FB</Color>
                    <Color x:Key="BatCaveChartFillColor">#332563EB</Color>
                    <Color x:Key="BatCaveChartGridColor">#335B6B7D</Color>
                    <Color x:Key="BatCaveSuccessColor">#FF047857</Color>
                    <Color x:Key="BatCaveWarningColor">#FFB45309</Color>
                    <Color x:Key="BatCaveTextPrimaryColor">#FF111827</Color>
                    <Color x:Key="BatCaveTextSecondaryColor">#FF4B5563</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="BatCavePageBackgroundColor">#FF171A1F</Color>
                    <Color x:Key="BatCaveSurfaceColor">#FF20242B</Color>
                    <Color x:Key="BatCaveSurfaceAltColor">#FF2A3038</Color>
                    <Color x:Key="BatCaveBorderColor">#FF3B4450</Color>
                    <Color x:Key="BatCavePrimaryColor">#FF7AA2FF</Color>
                    <Color x:Key="BatCaveSelectionColor">#FF26344F</Color>
                    <Color x:Key="BatCaveRowHoverColor">#FF242B35</Color>
                    <Color x:Key="BatCaveChartFillColor">#337AA2FF</Color>
                    <Color x:Key="BatCaveChartGridColor">#336B7788</Color>
                    <Color x:Key="BatCaveSuccessColor">#FF55D6A5</Color>
                    <Color x:Key="BatCaveWarningColor">#FFFFC857</Color>
                    <Color x:Key="BatCaveTextPrimaryColor">#FFF8FAFC</Color>
                    <Color x:Key="BatCaveTextSecondaryColor">#FFC7D0DC</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <Color x:Key="BatCavePageBackgroundColor">#FF000000</Color>
                    <Color x:Key="BatCaveSurfaceColor">#FF000000</Color>
                    <Color x:Key="BatCaveSurfaceAltColor">#FF0A0A0A</Color>
                    <Color x:Key="BatCaveBorderColor">#FFFFFFFF</Color>
                    <Color x:Key="BatCavePrimaryColor">#FFFFFF00</Color>
                    <Color x:Key="BatCaveSelectionColor">#FF1A1A1A</Color>
                    <Color x:Key="BatCaveRowHoverColor">#FF111111</Color>
                    <Color x:Key="BatCaveChartFillColor">#55FFFF00</Color>
                    <Color x:Key="BatCaveChartGridColor">#88FFFFFF</Color>
                    <Color x:Key="BatCaveSuccessColor">#FF00FF00</Color>
                    <Color x:Key="BatCaveWarningColor">#FFFFFF00</Color>
                    <Color x:Key="BatCaveTextPrimaryColor">#FFFFFFFF</Color>
                    <Color x:Key="BatCaveTextSecondaryColor">#FFFFFF00</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="BatCavePageBackgroundBrush" Color="{ThemeResource BatCavePageBackgroundColor}" />
            <SolidColorBrush x:Key="BatCaveSurfaceBrush" Color="{ThemeResource BatCaveSurfaceColor}" />
            <SolidColorBrush x:Key="BatCaveSurfaceAltBrush" Color="{ThemeResource BatCaveSurfaceAltColor}" />
            <SolidColorBrush x:Key="BatCaveBorderBrush" Color="{ThemeResource BatCaveBorderColor}" />
            <SolidColorBrush x:Key="BatCavePrimaryBrush" Color="{ThemeResource BatCavePrimaryColor}" />
            <SolidColorBrush x:Key="BatCaveSelectionBrush" Color="{ThemeResource BatCaveSelectionColor}" />
            <SolidColorBrush x:Key="BatCaveRowHoverBrush" Color="{ThemeResource BatCaveRowHoverColor}" />
            <SolidColorBrush x:Key="BatCaveChartFillBrush" Color="{ThemeResource BatCaveChartFillColor}" />
            <SolidColorBrush x:Key="BatCaveChartGridBrush" Color="{ThemeResource BatCaveChartGridColor}" />
            <SolidColorBrush x:Key="BatCaveSuccessBrush" Color="{ThemeResource BatCaveSuccessColor}" />
            <SolidColorBrush x:Key="BatCaveWarningBrush" Color="{ThemeResource BatCaveWarningColor}" />
            <SolidColorBrush x:Key="BatCaveTextPrimaryBrush" Color="{ThemeResource BatCaveTextPrimaryColor}" />
            <SolidColorBrush x:Key="BatCaveTextSecondaryBrush" Color="{ThemeResource BatCaveTextSecondaryColor}" />

            <Thickness x:Key="BatCavePagePadding">16</Thickness>
            <CornerRadius x:Key="BatCaveControlCornerRadius">6</CornerRadius>

            <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource BatCaveTextSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="80" />
            </Style>

            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource BatCaveTextPrimaryBrush}" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

{
  "name": "batcave-monitor",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json && npm run typecheck:node",
    "typecheck:node": "tsc --project tsconfig.node.json --noEmit",
    "lint": "oxlint src scripts vite.config.ts playwright.config.ts --deny-warnings",
    "format:check": "oxfmt --check src scripts vite.config.ts playwright.config.ts",
    "smoke:bridge": "node scripts/bridge-smoke.ts",
    "test:process-order": "node --test scripts/process-order.test.ts",
    "test:presentation": "node --test scripts/presentation.test.ts",
    "test:runtime-contract": "node --test scripts/runtime-contract.test.ts",
    "test:browser-fixture": "node --test scripts/browser-fixture.test.ts",
    "test:accessibility-fixtures": "node --test scripts/accessibility-fixtures.test.ts",
    "test:accessibility": "playwright test --config playwright.config.ts",
    "test:runtime-protocol": "node --test scripts/runtime-protocol.test.ts",
    "test:protocol-payload": "node --test scripts/protocol-payload-guardrail.test.ts",
    "test:update-lifecycle": "node --test scripts/update-lifecycle.test.ts",
    "benchmark:protocol-payload": "node scripts/protocol-payload-guardrail.ts",
    "verify": "npm run check && npm run format:check",
    "check": "npm run test:process-order && npm run test:presentation && npm run test:runtime-contract && npm run test:browser-fixture && npm run test:runtime-protocol && npm run test:protocol-payload && npm run test:update-lifecycle && npm run test:accessibility-fixtures && npm run smoke:bridge && npm run build && npm run typecheck && npm run lint",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "phosphor-svelte": "3.1.0",
    "uplot": "1.6.32"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "24.10.1",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "svelte": "5.56.4",
    "svelte-check": "4.4.6",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  }
}

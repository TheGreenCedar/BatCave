{
  "name": "batcave-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "oxlint src scripts vite.config.ts --deny-warnings",
    "format:check": "oxfmt --check src scripts vite.config.ts",
    "smoke:bridge": "node scripts/bridge-smoke.ts",
    "test:process-order": "node --test scripts/process-order.test.ts",
    "test:runtime-contract": "node --test scripts/runtime-contract.test.ts",
    "verify": "npm run check && npm run format:check",
    "check": "npm run test:process-order && npm run test:runtime-contract && npm run smoke:bridge && npm run build && npm run typecheck && npm run lint",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:dev:windows": "tauri dev --config src-tauri/tauri.windows.conf.json",
    "tauri:build:windows": "tauri build --config src-tauri/tauri.windows.conf.json",
    "tauri:dev:linux": "tauri dev --config src-tauri/tauri.linux.conf.json",
    "tauri:build:linux": "tauri build --config src-tauri/tauri.linux.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "uplot": "1.6.32"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "24.10.1",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "svelte": "5.56.4",
    "svelte-check": "4.4.6",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  }
}

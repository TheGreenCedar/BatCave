{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheGreenCedar/BatCave/blob/main/docs/evidence/releases/release-evidence-packet.schema.json",
  "title": "BatCave release evidence packet",
  "description": "Version 1 structural schema. The repository validator enforces exact URLs, release-asset roles, shared identity, required check IDs, package trust, stable ordering, and sensitive-data rejection.",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "packet_kind": { "const": "schema_fixture" }
        }
      },
      "then": {
        "properties": {
          "platform": {
            "type": "object",
            "properties": {
              "os_version": {
                "enum": [
                  "synthetic-linux-fixture",
                  "synthetic-macos-fixture",
                  "synthetic-windows-fixture"
                ]
              },
              "proof": {
                "type": "object",
                "properties": {
                  "source": { "const": "pending" },
                  "native": { "const": "pending" }
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "platform": {
            "type": "object",
            "properties": {
              "os_version": {
                "not": {
                  "enum": [
                    "synthetic-linux-fixture",
                    "synthetic-macos-fixture",
                    "synthetic-windows-fixture"
                  ]
                }
              },
              "proof": {
                "type": "object",
                "properties": {
                  "source": { "const": "source_enforced" },
                  "native": { "const": "observed" }
                }
              }
            }
          }
        }
      }
    }
  ],
  "required": [
    "schema_version",
    "packet_kind",
    "packet_id",
    "observed_at_utc",
    "release",
    "platform",
    "assets",
    "checks",
    "limitations"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "packet_kind": { "enum": ["release_evidence", "schema_fixture"] },
    "packet_id": { "$ref": "#/$defs/slug" },
    "observed_at_utc": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "release": { "$ref": "#/$defs/release" },
    "platform": { "$ref": "#/$defs/platform" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/asset" }
    },
    "checks": { "$ref": "#/$defs/checks" },
    "limitations": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/slug" },
      "additionalProperties": { "$ref": "#/$defs/limitation" }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "tag",
        "channel",
        "source_sha",
        "main_sha",
        "release_target_sha",
        "release_url",
        "workflow_run"
      ],
      "properties": {
        "repository": { "const": "TheGreenCedar/BatCave" },
        "tag": {
          "type": "string",
          "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        },
        "channel": { "enum": ["stable", "prerelease"] },
        "source_sha": { "$ref": "#/$defs/commitSha" },
        "main_sha": { "$ref": "#/$defs/commitSha" },
        "release_target_sha": { "$ref": "#/$defs/commitSha" },
        "release_url": { "type": "string", "format": "uri" },
        "workflow_run": {
          "type": "object",
          "additionalProperties": false,
          "required": ["workflow_file", "run_id", "run_attempt", "url"],
          "properties": {
            "workflow_file": { "const": ".github/workflows/release.yml" },
            "run_id": { "type": "integer", "minimum": 1 },
            "run_attempt": { "type": "integer", "minimum": 1 },
            "url": { "type": "string", "format": "uri" }
          }
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_contract_version",
        "profile_id",
        "proof",
        "os",
        "os_version",
        "architecture",
        "runtime",
        "package"
      ],
      "properties": {
        "support_contract_version": { "const": 1 },
        "profile_id": {
          "enum": [
            "debian-12-x86_64-glibc",
            "macos-12-universal",
            "ubuntu-22.04-x86_64-glibc",
            "windows-client-10-x86_64"
          ]
        },
        "proof": {
          "type": "object",
          "additionalProperties": false,
          "required": ["declaration", "source", "native"],
          "properties": {
            "declaration": { "const": "declared" },
            "source": { "enum": ["pending", "source_enforced"] },
            "native": { "enum": ["pending", "observed"] }
          }
        },
        "os": { "enum": ["windows", "linux", "macos"] },
        "os_version": { "type": "string", "minLength": 1 },
        "architecture": { "enum": ["x86_64", "arm64"] },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["libc_family"],
          "properties": {
            "libc_family": { "enum": ["glibc", "not_applicable"] }
          }
        },
        "package": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "architecture", "asset_name"],
          "properties": {
            "kind": {
              "enum": ["nsis", "deb", "appimage", "dmg", "macos_updater"]
            },
            "architecture": { "enum": ["x86_64", "universal"] },
            "asset_name": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "size_bytes",
        "sha256",
        "api_digest",
        "public_url",
        "attestation",
        "signatures"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 1 },
        "sha256": { "$ref": "#/$defs/digest" },
        "api_digest": { "$ref": "#/$defs/digest" },
        "public_url": { "type": "string", "format": "uri" },
        "attestation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["verified", "repository", "source_sha", "source_ref", "signer_workflow"],
          "properties": {
            "verified": { "const": true },
            "repository": { "const": "TheGreenCedar/BatCave" },
            "source_sha": { "$ref": "#/$defs/commitSha" },
            "source_ref": { "const": "refs/heads/main" },
            "signer_workflow": {
              "const": "TheGreenCedar/BatCave/.github/workflows/release.yml"
            }
          }
        },
        "signatures": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apple_notarization": { "$ref": "#/$defs/notarizationSignature" },
            "apple_staple": { "$ref": "#/$defs/stapleSignature" },
            "authenticode": { "$ref": "#/$defs/authenticodeSignature" },
            "contained_app_developer_id": {
              "$ref": "#/$defs/developerIdSignature"
            },
            "contained_app_notarization": {
              "$ref": "#/$defs/containedAppNotarizationSignature"
            },
            "contained_app_staple": {
              "$ref": "#/$defs/containedAppStapleSignature"
            },
            "developer_id": { "$ref": "#/$defs/developerIdSignature" },
            "tauri_updater": { "$ref": "#/$defs/tauriUpdaterSignature" }
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "verified"],
      "properties": {
        "identity": { "type": "string", "minLength": 1 },
        "verified": { "const": true }
      }
    },
    "authenticodeSignature": {
      "allOf": [
        { "$ref": "#/$defs/signature" },
        {
          "properties": {
            "identity": {
              "anyOf": [
                { "const": "synthetic Authenticode signer fixture" },
                { "pattern": "^sha256:[0-9a-f]{64}$" }
              ]
            }
          }
        }
      ]
    },
    "developerIdSignature": {
      "allOf": [
        { "$ref": "#/$defs/signature" },
        {
          "properties": {
            "identity": {
              "anyOf": [
                { "const": "synthetic Developer ID signer fixture" },
                {
                  "pattern": "^Developer ID Application: [^()]+ \\([A-Z0-9]{10}\\)$"
                }
              ]
            }
          }
        }
      ]
    },
    "notarizationSignature": {
      "allOf": [
        { "$ref": "#/$defs/signature" },
        {
          "properties": {
            "identity": {
              "anyOf": [
                { "const": "synthetic Apple notarization fixture" },
                {
                  "pattern": "^submission-id:[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
                }
              ]
            }
          }
        }
      ]
    },
    "containedAppNotarizationSignature": {
      "allOf": [
        { "$ref": "#/$defs/signature" },
        {
          "properties": {
            "identity": {
              "anyOf": [
                { "const": "synthetic contained-app notarization fixture" },
                {
                  "pattern": "^submission-id:[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
                }
              ]
            }
          }
        }
      ]
    },
    "stapleSignature": {
      "allOf": [
        { "$ref": "#/$defs/signature" },
        {
          "properties": {
            "identity": {
              "anyOf": [
                { "const": "synthetic stapled ticket fixture" },
                { "pattern": "^ticket-sha256:[0-9a-f]{64}$" }
              ]
            }
          }
        }
      ]
    },
    "containedAppStapleSignature": {
      "allOf": [
        { "$ref": "#/$defs/signature" },
        {
          "properties": {
            "identity": {
              "anyOf": [
                { "const": "synthetic contained-app stapled ticket fixture" },
                { "pattern": "^ticket-sha256:[0-9a-f]{64}$" }
              ]
            }
          }
        }
      ]
    },
    "tauriUpdaterSignature": {
      "allOf": [
        { "$ref": "#/$defs/signature" },
        {
          "properties": {
            "identity": {
              "enum": [
                "synthetic updater key fingerprint fixture",
                "sha256:0dad0009cf5cc87a778f2e951cefaa0faaba637b95a22f6f3064f12cd4136545"
              ]
            }
          }
        }
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["install", "runtime", "cleanup"],
      "properties": {
        "install": { "$ref": "#/$defs/checkGroup" },
        "runtime": { "$ref": "#/$defs/checkGroup" },
        "cleanup": { "$ref": "#/$defs/checkGroup" }
      }
    },
    "checkGroup": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/slug" },
      "additionalProperties": { "$ref": "#/$defs/check" }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "outcome"],
      "properties": {
        "status": { "enum": ["passed", "failed", "blocked", "not_applicable"] },
        "outcome": { "type": "string", "minLength": 1 }
      }
    },
    "limitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disposition", "summary"],
      "properties": {
        "disposition": { "enum": ["accepted", "blocked", "not_applicable"] },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
